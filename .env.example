# 复制为 .env，填入你的值，然后运行：
# Copy to .env, fill in your values, then run:
#   sudo ./install.sh --env-file .env --non-interactive -y
#
# 请保护真实 .env 文件；它可能包含 Telegram Bot Token。飞书 App Secret 只能通过独立文件提供，
# 不要直接写进 .env。
# Keep your real .env private. It may contain a Telegram bot token. Supply the Feishu App Secret only
# through a separate file; never put the literal secret in .env.

NOTIFY_CHANNELS=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 飞书非交互安装必须填写 FEISHU_RECEIVE_ID；交互安装留空时会自动扫描并按序号选人。更换 App ID 时也要重新填写。
# FEISHU_RECEIVE_ID is required for non-interactive Feishu installs. Leave it empty interactively to scan and choose; set it again when changing the App ID.
FEISHU_APP_ID=
FEISHU_RECEIVE_ID=
# 这里只填写凭据源文件路径，不能填写 App Secret 本身。该文件必须由 root 所有、不可为符号链接，且组/其他用户不可访问（建议 0600）。
# This is a source-file path, never the App Secret itself. It must be root-owned, not a symlink, and inaccessible to group/other users (0600 recommended).
# 安装后会转存为 systemd/root 凭据。/ The installer stores it in a systemd/root credential.
FEISHU_APP_SECRET_FILE=
CONFIG_VERSION=3

# 可选设置 / Optional settings
# 注意：如果值包含 # 字符，请用引号包裹，例如 HOST_LABEL="my#host"
# Note: if a value contains #, wrap it in quotes, e.g. HOST_LABEL="my#host"
CHECK_TIME=09:00
# 通知语言：zh 中文，en English
# Notification language: zh Chinese, en English
NOTIFY_LANG=zh
# 重复提醒模式 / reminder mode: once | daily | interval （默认/default daily）
DEDUP_MODE=daily
# 仅 interval 模式使用 / used only by interval mode
DEDUP_INTERVAL_DAYS=3
HOST_LABEL=
# 通知中的公网 IP：留空则运行时自动获取；如服务器出站 IP 不稳定，可手动填写。
# Public IP in notifications: leave empty to auto-detect at runtime; set manually if egress IP is not stable.
PUBLIC_IP=
# 是否显示公网 IP：1 显示（默认），0 不显示。
# Show public IP: 1 yes (default), 0 no.
INCLUDE_PUBLIC_IP=1
# 可选：无需处理时也发送 OK 通知；默认 0。
# Optional: send OK notification when no action is needed; default 0.
NOTIFY_OK=0
# 可选：升级成功后向已配置渠道发送通知；默认 0。
# Optional: notify configured channels after successful upgrade; default 0.
NOTIFY_UPGRADE=0
BACKEND=auto

# 安全更新看门狗（默认全开）/ Security-update watchdog (on by default)
# 检测自动更新机制是否健康（定时器禁用、上次失败、超期未更新、磁盘将满）；1 开，0 关。
# Detect whether the auto-update mechanism is healthy (timer disabled, last run failed, stale, low disk); 1 on, 0 off.
CHECK_UPDATE_HEALTH=1
# 超过该天数没有成功的自动安全更新即告警；0 关闭该项检查。
# Alert if no successful automatic security update for this many days; 0 disables this check.
STALE_UPDATE_DAYS=7
# 发行版安全支持终止（EOL）告警；1 开，0 关（如已购 Ubuntu ESM 等延长支持可设 0）。
# Warn on distro end-of-life (no more security updates); 1 on, 0 off (set 0 if you have extended support like Ubuntu ESM).
CHECK_EOL=1

# 可选布尔值：0 或 1 / Optional booleans: 0 or 1
SEND_TEST=0
SKIP_TELEGRAM_TEST=0
SKIP_FEISHU_TEST=0
ALLOW_BEST_EFFORT=0
