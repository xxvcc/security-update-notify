# 复制为 .env，填入你的值，然后运行：
# Copy to .env, fill in your values, then run:
#   sudo ./install.sh --env-file .env --non-interactive -y
#
# 请保护真实 .env 文件；它可能包含 Telegram Bot Token。
# Keep your real .env private. It may contain a Telegram bot token.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CONFIG_VERSION=2

# 可选设置 / Optional settings
# 注意：如果值包含 # 字符，请用引号包裹，例如 HOST_LABEL="my#host"
# Note: if a value contains #, wrap it in quotes, e.g. HOST_LABEL="my#host"
CHECK_TIME=09:00
# Telegram 提醒语言：zh 中文，en English
# Telegram alert language: zh Chinese, en English
NOTIFY_LANG=zh
DEDUP_MODE=interval
DEDUP_INTERVAL_DAYS=3
HOST_LABEL=
# 通知中的公网 IP：留空则运行时自动获取；如服务器出站 IP 不稳定，可手动填写。
# Public IP in notifications: leave empty to auto-detect at runtime; set manually if egress IP is not stable.
PUBLIC_IP=
# 是否显示公网 IP：1 显示（默认），0 不显示。
# Show public IP: 1 yes (default), 0 no.
INCLUDE_PUBLIC_IP=1
# 可选：无需处理时也发送 OK 通知；默认 0。
# Optional: send OK notification when no action is needed; default 0.
NOTIFY_OK=0
# 可选：升级成功后发送 Telegram 通知；默认 0。
# Optional: send Telegram notification after successful upgrade; default 0.
NOTIFY_UPGRADE=0
BACKEND=auto

# 可选布尔值：0 或 1 / Optional booleans: 0 or 1
SEND_TEST=0
SKIP_TELEGRAM_TEST=0
ALLOW_BEST_EFFORT=0
