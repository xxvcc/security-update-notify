reboot_required=0
reboot_pkgs=""
restart_attention=0
restart_summary=""
restart_signal=""
update_summary=""

check_apt() {
  if [[ "$TEST_REBOOT" -eq 1 ]]; then
    reboot_required=1
    reboot_pkgs=$'linux-image-amd64\nTEST-MODE-no-real-reboot'
    restart_summary=$'NEEDRESTART-VER: test\nNEEDRESTART-KCUR: test-current\nNEEDRESTART-KEXP: test-expected\nNEEDRESTART-KSTA: 3\nNEEDRESTART-SVC: ssh.service'
    restart_attention=1
    return
  fi
  if [[ -f /var/run/reboot-required ]]; then
    reboot_required=1
    reboot_pkgs="$(cat /var/run/reboot-required.pkgs 2>/dev/null | sed '/^$/d' | sort -u)"
  fi
  if command -v needrestart >/dev/null 2>&1; then
    # 只取 stdout（批处理字段）；stderr 的瞬时告警不进摘要/哈希，避免污染去重。
    # Take stdout only (batch fields); stderr's transient warnings stay out of the summary/hash.
    restart_summary="$(needrestart -b 2>/dev/null || true)"
    local kcur kexp ksta
    kcur="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KCUR:/{print $2; exit}')"
    kexp="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KEXP:/{print $2; exit}')"
    ksta="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KSTA:/{print $2; exit}')"
    # 关注信号只取：内核确实更换（KCUR!=KEXP）、KSTA 为 2/3（ABI/版本升级待重启），以及
    # 需要重启的 systemd 服务（SVC）。不再因 KSTA=0（未知）或 SESS/AUX（用户会话，含管理员
    # 自己的 SSH 登录）误报——这些只在摘要里作信息展示。与 dnf 端 needs-restarting -s 的策略一致。
    # Attention only from: a real kernel change (KCUR!=KEXP), KSTA 2/3 (ABI/version upgrade pending),
    # and systemd services needing restart (SVC). No longer triggered by KSTA=0 (unknown) or SESS/AUX
    # (user sessions incl. the admin's own SSH login) — those are shown in the summary only. Parity
    # with the dnf needs-restarting -s policy.
    [[ -n "$kcur" && -n "$kexp" && "$kcur" != "$kexp" ]] && restart_attention=1
    [[ "$ksta" == "2" || "$ksta" == "3" ]] && restart_attention=1
    printf '%s\n' "$restart_summary" | grep -Eq '^NEEDRESTART-SVC:' && restart_attention=1
    # 去重哈希用的稳定信号：只含决策相关、跨周期稳定的字段（内核 + 服务），不含瞬时输出。
    # Stable signal for the dedup hash: only decision-relevant, cross-run-stable fields (kernel + services).
    restart_signal="$(printf 'KCUR=%s\nKEXP=%s\nKSTA=%s\n%s\n' "$kcur" "$kexp" "$ksta" \
      "$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-SVC:/{print $2}' | sed '/^$/d' | sort -u)")"
  else
    restart_summary="needrestart 命令不存在 / needrestart command not found"
  fi
}

check_dnf() {
  if [[ "$TEST_REBOOT" -eq 1 ]]; then
    reboot_required=1
    reboot_pkgs=$'kernel\nTEST-MODE-no-real-reboot'
    restart_summary=$'needs-restarting -r:\nReboot is required to ensure that your system benefits from these updates.\n\nneeds-restarting -s:\ntest-service.service'
    restart_attention=1
    return
  fi
  if command -v needs-restarting >/dev/null 2>&1; then
    local nr_r rc nr_svc nr_has_s
    rc=0
    nr_r="$(needs-restarting -r 2>&1)" || rc=$?
    # 探测本机 needs-restarting 是否支持 -s（仅列服务）。老版 dnf-utils 不支持时，退回“仅按
    # 整机重启判断”（保守、不误报），并在摘要里给出可见提示，而不是静默丢失服务检测。
    # Probe whether this needs-restarting supports -s (services only). On older dnf-utils that lack it,
    # degrade to reboot-only (conservative, no false alerts) with a visible note in the summary,
    # rather than silently losing service-restart detection.
    nr_has_s=0
    needs-restarting --help 2>&1 | grep -q -- '-s' && nr_has_s=1
    # 优先按 needs-restarting -r 的输出文案判断是否需要整机重启，避免把命令本身的报错
    # （权限不足、异常退出等任何非零码）误判为“需要重启”。退出码 1 是其表示“需要重启”的
    # 约定值，仅作为文案无法匹配时的回退；其它非零码视为命令出错，不作为重启信号。
    # Decide a full reboot from needs-restarting -r's message first, so that command errors
    # (insufficient privileges, crashes, any non-zero code) are not mistaken for "reboot required".
    # Exit code 1 is its documented "reboot required" signal and is used only as a fallback when the
    # message does not match; other non-zero codes are treated as errors, not a reboot signal.
    if printf '%s\n' "$nr_r" | grep -qiE 'reboot is required'; then
      reboot_required=1
    elif printf '%s\n' "$nr_r" | grep -qiE 'reboot should not be necessary|no core libraries'; then
      reboot_required=0
    elif [[ "$rc" -eq 1 ]]; then
      reboot_required=1
    fi
    # 只用“需要重启的 systemd 服务”（needs-restarting -s）作为关注信号。裸 needs-restarting 会
    # 列出所有仍在使用旧库的普通进程，在长期运行的系统上几乎总是非空，会造成每个周期都误报。
    # Use only systemd services that need restarting (needs-restarting -s) as the attention signal.
    # Bare needs-restarting lists every process still using an outdated library and is almost always
    # non-empty on long-running systems, which would otherwise raise a false alert every cycle.
    if [[ "$nr_has_s" -eq 1 ]]; then
      nr_svc="$(needs-restarting -s 2>/dev/null | sed '/^$/d' | sort -u || true)"
    else
      nr_svc=""
    fi
    if printf '%s\n' "$nr_svc" | sed '/^$/d' | grep -q .; then
      restart_attention=1
    fi
    if [[ "$nr_has_s" -eq 1 ]]; then
      restart_summary="needs-restarting -r:\n${nr_r}\n\nneeds-restarting -s:\n${nr_svc}"
    else
      restart_summary="needs-restarting -r:\n${nr_r}\n\n此版本 needs-restarting 不支持 -s，仅按整机重启判断。/ This needs-restarting lacks -s; reboot-only detection."
    fi
    # 稳定去重信号：服务列表（reboot_required 已单独进哈希）。
    # Stable dedup signal: the service list (reboot_required is hashed separately).
    restart_signal="$nr_svc"
  else
    restart_summary="needs-restarting 命令不存在；请安装 dnf-utils/yum-utils / needs-restarting command not found; install dnf-utils/yum-utils"
  fi
  if command -v dnf >/dev/null 2>&1; then
    update_summary="$(dnf -q updateinfo list security updates 2>/dev/null | sed -n '1,40p' || true)"
  fi
  # 只取像“包名.架构”的行作为相关包，过滤表头/汇总等杂质（$NF 直接取会混入噪声）。
  # Keep only rows whose last field looks like name.arch (filter header/summary noise that $NF would leak).
  reboot_pkgs="$(printf '%s\n' "$update_summary" | awk '$NF ~ /\.(x86_64|noarch|aarch64|i686|ppc64le|s390x)$/ {print $NF}' | sed '/^$/d' | sort -u | sed -n '1,40p')"
}

format_restart_summary() {
  local lang="$1" summary kcur kexp ksta services service_count other_count s_unsupported
  summary="${restart_summary//\\n/$'\n'}"
  case "$BACKEND" in
    apt)
      kcur="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KCUR:/{print $2; exit}')"
      kexp="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KEXP:/{print $2; exit}')"
      ksta="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KSTA:/{print $2; exit}')"
      services="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-SVC:/{print $2}' | sed '/^$/d' | sort -u)"
      service_count="$(printf '%s\n' "$services" | sed '/^$/d' | wc -l | tr -d ' ')"
      other_count="$(printf '%s\n' "$summary" | grep -Ec '^NEEDRESTART-(AUX|SESS|UCSTA|UCCUR|UCEXP):' || true)"

      if [[ "$lang" == "en" ]]; then
        [[ -n "$kcur" || -n "$kexp" ]] && printf 'Kernel: current %s, expected %s\n' "${kcur:-unknown}" "${kexp:-unknown}"
        [[ -n "$ksta" ]] && printf 'Kernel status code: %s\n' "$ksta"
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf 'Services to review/restart (%s):\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ... and %s more\n' "$((service_count - 12))"
        fi
        [[ "${other_count:-0}" -gt 0 ]] && printf 'Additional sessions/containers/processes need review. Run needrestart on the server for details.\n'
        [[ -z "$kcur$kexp$services" && "${other_count:-0}" -eq 0 ]] && printf 'No detailed restart list was available. Run needrestart -b on the server for details.\n'
      else
        [[ -n "$kcur" || -n "$kexp" ]] && printf '内核：当前 %s，建议 %s\n' "${kcur:-未知}" "${kexp:-未知}"
        [[ -n "$ksta" ]] && printf '内核状态码：%s\n' "$ksta"
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf '建议评估/重启的服务（%s 个）：\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ……另有 %s 个\n' "$((service_count - 12))"
        fi
        [[ "${other_count:-0}" -gt 0 ]] && printf '另有用户会话、容器或进程需要关注；可在服务器上运行 needrestart 查看详情。\n'
        [[ -z "$kcur$kexp$services" && "${other_count:-0}" -eq 0 ]] && printf '没有拿到详细重启列表；可在服务器上运行 needrestart -b 查看详情。\n'
      fi
      ;;
    dnf)
      services="$(printf '%s\n' "$summary" | awk '/^needs-restarting -s:$/{f=1; next} /^needs-restarting/{f=0} f && NF {print}' | sed '/^$/d' | sort -u)"
      service_count="$(printf '%s\n' "$services" | sed '/^$/d' | wc -l | tr -d ' ')"
      s_unsupported=0
      [[ "$summary" == *"lacks -s"* || "$summary" == *"不支持 -s"* ]] && s_unsupported=1
      if [[ "$lang" == "en" ]]; then
        [[ "$reboot_required" -eq 1 ]] && printf 'Full reboot: required by needs-restarting -r\n'
        [[ "$s_unsupported" -eq 1 ]] && printf 'Note: this needs-restarting lacks -s; per-service detection unavailable (reboot-only).\n'
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf 'Services to review/restart (%s):\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ... and %s more\n' "$((service_count - 12))"
        elif [[ "$reboot_required" -ne 1 && "$s_unsupported" -eq 0 ]]; then
          printf 'No services were reported as needing a restart. Run needs-restarting on the server for details.\n'
        fi
      else
        [[ "$reboot_required" -eq 1 ]] && printf '整机重启：needs-restarting -r 判断为需要\n'
        [[ "$s_unsupported" -eq 1 ]] && printf '提示：此版本 needs-restarting 不支持 -s，无法按服务检测（仅整机重启）。\n'
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf '建议评估/重启的服务（%s 个）：\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ……另有 %s 个\n' "$((service_count - 12))"
        elif [[ "$reboot_required" -ne 1 && "$s_unsupported" -eq 0 ]]; then
          printf '没有服务被报告需要重启；可在服务器上运行 needs-restarting 查看详情。\n'
        fi
      fi
      ;;
  esac
}

case "$BACKEND" in
  apt) check_apt ;;
  dnf) check_dnf ;;
  *) say "不支持的后端: $BACKEND" "Unsupported backend: $BACKEND" >&2; exit 2 ;;
esac
check_update_health
collect_security_updates
check_eol

# 看门狗附加段：自动更新异常、待安装安全更新、EOL（用真实换行，不受后面 \n 转换影响）。
# Watchdog extra sections (real newlines; unaffected by the later literal-\n conversion).
extra_zh=""; extra_en=""
if [[ -n "$HEALTH_TXT_ZH" ]]; then
  extra_zh+=$'\n\n'"⚠️ 自动安全更新机制异常："$'\n'"$HEALTH_TXT_ZH"
  extra_en+=$'\n\n'"⚠️ Automatic security-update mechanism problem:"$'\n'"$HEALTH_TXT_EN"
fi
if [[ -n "$PENDING_TXT_ZH" ]]; then
  extra_zh+=$'\n\n'"$PENDING_TXT_ZH"
  extra_en+=$'\n\n'"$PENDING_TXT_EN"
fi
if [[ -n "$EOL_TXT_ZH" ]]; then
  extra_zh+=$'\n\n'"$EOL_TXT_ZH"
  extra_en+=$'\n\n'"$EOL_TXT_EN"
fi

if [[ "$reboot_required" -eq 0 && "$restart_attention" -eq 0 && "$HEALTH_ATTENTION" -eq 0 && "$EOL_ATTENTION" -eq 0 ]]; then
  log_event "check ok backend=$BACKEND host=$HOST no_attention=1 pending_sec=$PENDING_SEC_COUNT"
  if [[ "$SEND_OK" -eq 1 || "${NOTIFY_OK:-0}" == "1" ]]; then
    zh_msg="✅ 安全更新检查正常\n\n主机：$HOST${PUBLIC_IP_LINE_ZH}\n系统：$OS\n后端：$BACKEND\n当前内核：$KERNEL\n时间：$NOW\n\n没有发现整机重启或服务/进程重启需要关注的问题。${extra_zh}"
    en_msg="✅ Security update check OK\n\nHost: $HOST${PUBLIC_IP_LINE_EN}\nOS: $OS\nBackend: $BACKEND\nCurrent kernel: $KERNEL\nTime: $NOW\n\nNo reboot or service/process restart requiring attention was detected.${extra_en}"
    if [[ "$NOTIFY_LANG" == "en" ]]; then
      msg="$en_msg"
    else
      msg="$zh_msg"
    fi
  else
    log_event "silent ok backend=$BACKEND host=$HOST"
    exit 0
  fi
else
  pkgs_zh="无"
  pkgs_en="None"
  if [[ -n "$reboot_pkgs" ]]; then
    pkgs_zh="$reboot_pkgs"
    pkgs_en="$reboot_pkgs"
  fi
  rs_zh="$(format_restart_summary zh | sed -n '1,80p')"
  rs_en="$(format_restart_summary en | sed -n '1,80p')"
  reboot_text_zh="$([[ "$reboot_required" -eq 1 ]] && echo '需要' || echo '暂不需要')"
  reboot_text_en="$([[ "$reboot_required" -eq 1 ]] && echo 'Required' || echo 'Not required for now')"
  log_event "alert backend=$BACKEND host=$HOST reboot=$reboot_required svc_attn=$restart_attention health=$HEALTH_ATTENTION eol=$EOL_ATTENTION pending_sec=$PENDING_SEC_COUNT"
  zh_msg="⚠️ 安全更新后需要处理\n\n主机：$HOST${PUBLIC_IP_LINE_ZH}\n系统：$OS\n后端：$BACKEND\n当前内核：$KERNEL\n时间：$NOW\n\n整机重启：$reboot_text_zh\n相关包/安全更新：\n$pkgs_zh\n\n重启检测摘要：\n$rs_zh${extra_zh}\n\n建议：请在方便的维护窗口 SSH 登录该服务器后手动执行 reboot；如只是服务需要重启，可先评估并重启对应服务。"
  en_msg="⚠️ Security update action required\n\nHost: $HOST${PUBLIC_IP_LINE_EN}\nOS: $OS\nBackend: $BACKEND\nCurrent kernel: $KERNEL\nTime: $NOW\n\nFull reboot: $reboot_text_en\nRelated packages/security updates:\n$pkgs_en\n\nRestart detection summary:\n$rs_en${extra_en}\n\nRecommendation: SSH into this server during a suitable maintenance window and run reboot if a full reboot is required. If only services need restarting, review them first and restart the affected services manually."
  if [[ "$NOTIFY_LANG" == "en" ]]; then
    msg="$en_msg"
  else
    msg="$zh_msg"
  fi
fi
msg="${msg//\\n/$'\n'}"


# 去重哈希只基于决策相关、跨周期稳定的字段：排除 PUBLIC_IP（动态出口 IP 会变）与含瞬时输出
# 的原始摘要，改用 restart_signal（规范化的内核/服务信号），避免同一状态被反复发送。
# Dedup hash uses only decision-relevant, cross-run-stable fields: excludes PUBLIC_IP (dynamic egress
# IP) and the raw summary (transient output), using restart_signal (normalized kernel/service signal).
alert_hash="$(printf '%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n' "$HOST" "$BACKEND" "$NOTIFY_LANG" "$reboot_required" "$reboot_pkgs" "$restart_attention" "$restart_signal" "$HEALTH_ATTENTION" "$HEALTH_SIG" "$EOL_ATTENTION" "$EOL_SIG" | sha256sum | awk '{print $1}')"
last_hash="$(cat "$STATE_FILE" 2>/dev/null || true)"
last_sent="$(cat "$STATE_TIME_FILE" 2>/dev/null || echo 0)"
now_epoch="$(date +%s)"
dedup_mode="${DEDUP_MODE:-daily}"
dedup_days="${DEDUP_INTERVAL_DAYS:-3}"
[[ "$dedup_days" =~ ^[0-9]+$ && "$dedup_days" -ge 1 ]] || dedup_days=3
should_send=1
if [[ "$NO_DEDUPE" -ne 1 && "$alert_hash" == "$last_hash" ]]; then
  case "$dedup_mode" in
    once|always) should_send=0 ;;  # always 为旧名，兼容保留 / always kept as a legacy alias for once
    daily)
      last_day="$(date -d "@$last_sent" +%F 2>/dev/null || echo '')"
      today="$(date +%F)"
      [[ "$last_day" == "$today" ]] && should_send=0
      ;;
    interval|*)
      interval_seconds=$(( dedup_days * 86400 ))
      if [[ "$last_sent" =~ ^[0-9]+$ ]] && (( now_epoch - last_sent < interval_seconds )); then should_send=0; fi
      ;;
  esac
fi
if [[ "$should_send" -eq 0 ]]; then
  log_event "dedup suppressed backend=$BACKEND host=$HOST mode=$dedup_mode hash=$alert_hash"
  exit 0
fi

if [[ -z "${TELEGRAM_BOT_TOKEN:-}" || -z "${TELEGRAM_CHAT_ID:-}" ]]; then
  say "在 $ENV_FILE 中缺少 TELEGRAM_BOT_TOKEN 或 TELEGRAM_CHAT_ID" "Missing TELEGRAM_BOT_TOKEN or TELEGRAM_CHAT_ID in $ENV_FILE" >&2
  exit 2
fi

if telegram_send_message "$msg"; then
  # 原子写状态：临时文件 + rename，避免崩溃或磁盘满时留下被截断/清空的状态文件（">" 会先截断再写）。
  # hash 先于时间戳落盘；即便两次 rename 之间崩溃，残留的旧时间戳只会让下次更倾向“发送”，绝不会静默抑制真实告警。
  # Atomic state write: temp file + rename so a crash/ENOSPC can't leave a truncated/empty state file
  # ('>' truncates before writing). Hash is committed before the timestamp; a crash between the two
  # renames leaves an older timestamp, which only biases the next run toward sending, never toward
  # silently suppressing a real alert.
  if state_tmp="$(mktemp "$STATE_DIR/.state.XXXXXX" 2>/dev/null)" \
     && time_tmp="$(mktemp "$STATE_DIR/.state.XXXXXX" 2>/dev/null)" \
     && printf '%s\n' "$alert_hash" >"$state_tmp" \
     && printf '%s\n' "$now_epoch" >"$time_tmp" \
     && mv -f "$state_tmp" "$STATE_FILE" 2>/dev/null \
     && mv -f "$time_tmp" "$STATE_TIME_FILE" 2>/dev/null; then
    :
  else
    # mktemp/写入/rename 任一步失败（如 STATE_DIR 权限或空间问题）时，清理临时文件并回退到直接写，保持原有行为。
    # If any step fails (e.g. STATE_DIR perms/space), clean up temp files and fall back to direct writes.
    rm -f "${state_tmp:-}" "${time_tmp:-}" 2>/dev/null || true
    printf '%s\n' "$alert_hash" >"$STATE_FILE" 2>/dev/null || true
    printf '%s\n' "$now_epoch" >"$STATE_TIME_FILE" 2>/dev/null || true
  fi
  log_event "telegram sent backend=$BACKEND host=$HOST reboot_required=$reboot_required restart_attention=$restart_attention hash=$alert_hash"
else
  log_event "telegram failed backend=$BACKEND host=$HOST"
  say "Telegram 通知发送失败" "Telegram notification failed" >&2
  exit 1
fi
