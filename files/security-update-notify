safe_release_archive() {
  local archive="$1" topdir="$2" entry listing_type
  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    case "$entry" in
      /*|../*|*/../*|*/..|..) say "压缩包中存在不安全路径: $entry" "Unsafe path in archive: $entry" >&2; exit 1 ;;
    esac
    case "$entry" in
      "$topdir"|"$topdir/"|"$topdir"/*) ;;
      *) say "压缩包中存在非预期路径: $entry" "Unexpected path in archive: $entry" >&2; exit 1 ;;
    esac
  done < <(env -u TAR_OPTIONS -u GZIP -u BZIP2 -u XZ_OPT tar -tzf "$archive")
  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    listing_type="${entry:0:1}"
    case "$listing_type" in
      -|d) ;;
      *) say "压缩包中存在不支持的条目类型: $entry" "Unsupported archive entry type: $entry" >&2; exit 1 ;;
    esac
  done < <(env -u TAR_OPTIONS -u GZIP -u BZIP2 -u XZ_OPT tar -tzvf "$archive")
}

verify_release_signature() {
  local sig_file="$1" archive="$2" gpg_home fpr
  [[ -n "$RELEASE_SIGNING_FINGERPRINT" ]] || { say "未配置签名指纹；拒绝升级" "No signing fingerprint configured; refusing to upgrade" >&2; exit 1; }
  gpg_home="$(mktemp -d)"
  chmod 700 "$gpg_home"
  release_signing_public_key | GNUPGHOME="$gpg_home" gpg --batch --import >/dev/null 2>&1 \
    || { rm -rf "$gpg_home"; say "导入签名公钥失败；拒绝升级" "Failed to import signing public key; refusing to upgrade" >&2; exit 1; }
  fpr="$(GNUPGHOME="$gpg_home" gpg --batch --with-colons --list-keys 2>/dev/null | awk -F: '$1=="fpr"{print $10; exit}')"
  [[ "$fpr" == "$RELEASE_SIGNING_FINGERPRINT" ]] \
    || { rm -rf "$gpg_home"; say "签名公钥指纹不匹配（期望 $RELEASE_SIGNING_FINGERPRINT，实际 ${fpr:-none}）；拒绝升级" "Signing key fingerprint mismatch; refusing to upgrade" >&2; exit 1; }
  GNUPGHOME="$gpg_home" gpg --batch --verify "$sig_file" "$archive" >/dev/null 2>&1 \
    || { rm -rf "$gpg_home"; say "签名校验失败；拒绝升级" "Signature verification failed; refusing to upgrade" >&2; exit 1; }
  rm -rf "$gpg_home"
  say "签名校验通过 (${RELEASE_SIGNING_FINGERPRINT})" "Signature verified (${RELEASE_SIGNING_FINGERPRINT})"
}

run_self_upgrade() {
  # 不再把远程脚本 `curl ... | bash` 直接交给 root 执行；改为直接下载 GitHub 发布包，
  # 校验 sha256，并用本程序内置（pin）的指纹强制校验 GPG 签名（默认 fail-closed），
  # 通过后才运行已校验包内的 install.sh。
  # No longer pipe a remote script into root bash. Instead download the GitHub release directly,
  # verify sha256, and require a GPG signature against the fingerprint pinned in this program
  # (fail-closed by default); only then run install.sh from the verified package.
  local disp; disp="${UI_LANG:-${NOTIFY_LANG:-zh}}"
  if [[ "$(id -u)" -ne 0 ]]; then
    command -v sudo >/dev/null 2>&1 || { say "升级需要 root 权限" "Root privileges are required to upgrade" >&2; exit 1; }
    exec sudo "$0" --upgrade --lang "$disp"
  fi
  local c
  for c in tar sha256sum mktemp python3 env; do
    command -v "$c" >/dev/null 2>&1 || { say "升级需要命令: $c" "Upgrade requires command: $c" >&2; exit 1; }
  done

  local latest tmp pkg pkgdir url sha_url sig_url expected rc pkg_version
  if ! latest="$(latest_release_version)"; then
    say "无法获取最新版本" "Failed to fetch latest version" >&2
    exit 1
  fi
  [[ "$latest" =~ ^[0-9A-Za-z][0-9A-Za-z._-]*$ ]] || { say "无效的最新版本号: $latest" "Invalid latest version: $latest" >&2; exit 1; }
  if [[ "$latest" != "$VERSION" ]] && ! is_newer_version "$VERSION" "$latest"; then
    say "本地版本 $VERSION 高于或等于最新发布 $latest，不自动升级。" "Local version $VERSION is at or above latest release $latest; not upgrading." >&2
    exit 0
  fi
  if [[ "$latest" == "$VERSION" ]]; then
    say "已经是最新版本 $VERSION" "Already up to date: $VERSION"
    exit 0
  fi

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT
  pkg="security-update-notify-${latest}.tar.gz"
  pkgdir="security-update-notify-${latest}"
  url="https://github.com/${REPO}/releases/download/v${latest}/${pkg}"
  sha_url="${url}.sha256"
  sig_url="${url}.asc"

  say "正在下载并校验发布包: $VERSION -> $latest" "Downloading and verifying release: $VERSION -> $latest"
  download_release_file "$url" "$tmp/$pkg" || { say "下载发布包失败" "Failed to download release" >&2; exit 1; }
  download_release_file "$sha_url" "$tmp/$pkg.sha256" || { say "下载校验文件失败" "Failed to download checksum" >&2; exit 1; }

  expected="$(awk 'NF {print $1; exit}' "$tmp/$pkg.sha256")"
  [[ "$expected" =~ ^[A-Fa-f0-9]{64}$ ]] || { say "无效的校验文件" "Invalid checksum file" >&2; exit 1; }
  ( cd "$tmp" && printf '%s  %s\n' "$expected" "$pkg" | sha256sum -c - ) >/dev/null 2>&1 \
    || { say "sha256 校验失败；拒绝升级" "Checksum verification failed; refusing to upgrade" >&2; exit 1; }

  # GPG 签名校验在解包前完成：公钥内置并 pin 指纹，避免从未验证归档中取信任根。
  # Verify the GPG signature before extraction: the public key is embedded and fingerprint-pinned,
  # so the trust root is not read from the unverified archive.
  # gpg 可用时，签名恒为必需：即使攻击者故意让 .asc 下载失败（MITM/被控镜像返回 404），也一律
  # 拒绝，绝不因缺签名而静默降级到 sha256-only（sha256 文件同样由攻击者提供，形同虚设）。
  # sha256-only 分支只在“本机确实没有 gpg”且运维显式 opt-in 时保留，无法被网络攻击者触发。
  # When gpg is available a signature is mandatory: even if an attacker makes the .asc download fail
  # (MITM/compromised mirror returning 404) we refuse, and never silently downgrade to sha256-only
  # (the sha256 file is attacker-supplied too). The sha256-only branch remains only for hosts that
  # genuinely lack gpg AND explicitly opt in, so a network attacker cannot trigger a downgrade.
  if command -v gpg >/dev/null 2>&1; then
    download_release_file "$sig_url" "$tmp/$pkg.asc" 2>/dev/null \
      || { say "缺少发布签名（.asc）；gpg 可用时签名为必需，拒绝升级。" "Release signature (.asc) is missing; a signature is mandatory when gpg is available. Refusing to upgrade." >&2; exit 1; }
    verify_release_signature "$tmp/$pkg.asc" "$tmp/$pkg"
  elif [[ "$UPGRADE_ALLOW_UNSIGNED" == "1" ]]; then
    say "警告：本机没有 gpg 且已设置 SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED=1，仅校验 sha256（不推荐）。" "WARNING: gpg is not installed and SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED=1; sha256-only verification (not recommended)." >&2
  else
    say "缺少 gpg 且未设置 SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED=1；为安全起见拒绝升级。" "Missing gpg and SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED is not set; refusing to upgrade for safety." >&2
    exit 1
  fi

  # 安全解包：拒绝路径穿越、非预期顶层目录，以及 symlink/hardlink/device 等特殊条目。
  # Safe extraction: reject path traversal, unexpected top-level paths, and special entries
  # such as symlinks, hardlinks and devices.
  safe_release_archive "$tmp/$pkg" "$pkgdir"
  # --no-same-permissions：不从归档恢复 setuid/setgid 等特殊权限位（纵深防御：即便签名者被攻破，
  # 也不会因归档内的权限位而落地 setuid 文件）。
  # --no-same-permissions: do not restore setuid/setgid/special bits from the archive (defense in depth:
  # even if the signer were compromised, no setuid file lands via archived permission bits).
  ( cd "$tmp" && env -u TAR_OPTIONS -u GZIP -u BZIP2 -u XZ_OPT tar --no-same-owner --no-same-permissions -xzf "$pkg" ) || { say "解包失败" "Extraction failed" >&2; exit 1; }

  [[ -f "$tmp/$pkgdir/install.sh" ]] || { say "发布包缺少 install.sh" "Release is missing install.sh" >&2; exit 1; }
  # 版本绑定：已校验发布包内声明的 VERSION 必须等于本次请求的 latest。顶层目录名已由
  # safe_release_archive pin 到 security-update-notify-<latest>，此处再核对程序内 VERSION，
  # 双重防止“签名集合内回滚/版本错配”。
  # Version binding: the verified package's declared VERSION must equal the requested latest. The top-dir
  # name is already pinned by safe_release_archive; re-checking the in-file VERSION guards against any
  # rollback/version mismatch within the signed set.
  pkg_version="$(sed -n 's/^VERSION="\([^"]*\)".*/\1/p' "$tmp/$pkgdir/files/security-update-notify" 2>/dev/null | head -1)"
  [[ "$pkg_version" == "$latest" ]] || { say "发布包内版本($pkg_version)与请求版本($latest)不一致；拒绝升级。" "Package version ($pkg_version) does not match requested version ($latest); refusing to upgrade." >&2; exit 1; }
  chmod 0755 "$tmp/$pkgdir/install.sh" 2>/dev/null || true
  say "正在以已校验的发布包升级..." "Upgrading from the verified release..."
  cd "$tmp/$pkgdir" || { say "进入解包目录失败" "Failed to enter extracted directory" >&2; exit 1; }
  rc=0
  SECURITY_UPDATE_NOTIFY_UPGRADE=1 ./install.sh --non-interactive -y --lang "$disp" || rc=$?
  cd / || true
  rm -rf "$tmp"
  trap - EXIT
  exit "$rc"
}

if [[ "$SELF_UPGRADE" -eq 1 ]]; then
  run_self_upgrade
fi

mkdir -p "$STATE_DIR"
