#!/usr/bin/env bash
# 故意不加 -e：后端检测命令（needrestart、needs-restarting）的非零退出码不应中断通知流程。
# Intentionally omit -e: non-zero exits from backend detection commands must not abort the notification flow.
set -uo pipefail
# 固定 locale，让 needrestart/needs-restarting 文案匹配、sort -V、awk/sed 字段解析在任何
# 系统语言下都确定（仅影响解析；消息正文是原始 UTF-8 字节，不受影响）。
# Pin the locale so message matching, sort -V and awk/sed field parsing are deterministic under
# any system language (parsing only; message bodies are raw UTF-8 bytes and are unaffected).
export LC_ALL=C

ENV_FILE="${SECURITY_UPDATE_NOTIFY_ENV:-/etc/security-update-notify/telegram.env}"
STATE_DIR="/var/lib/security-update-notify"
STATE_FILE="$STATE_DIR/last-alert.sha256"
STATE_TIME_FILE="$STATE_DIR/last-alert.sent_at"
LOCK_FILE="/run/security-update-notify.lock"
VERSION="1.8.0"
REPO="${SECURITY_UPDATE_NOTIFY_REPO:-xxvcc/security-update-notify}"
RELEASE_SIGNING_FINGERPRINT="${SECURITY_UPDATE_NOTIFY_SIGNING_FINGERPRINT:-C678256ACBFC6491BF5076655F3AE24999921FFC}"
UPGRADE_ALLOW_UNSIGNED="${SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED:-0}"
LOG_FILE="/var/log/security-update-notify.log"
TEST_REBOOT=0
SEND_OK=0
NO_DEDUPE=0
DOCTOR=0
DOCTOR_SKIP_TELEGRAM=0
CHECK_UPGRADE=0
SELF_UPGRADE=0
UPGRADE_NOTICE=0
UPGRADE_FROM=""
UPGRADE_TO=""
UI_LANG="${UI_LANG:-${SUN_LANG:-}}"

# 双语输出助手：UI_LANG/--lang 优先，否则跟随 NOTIFY_LANG，默认 zh。
# Bilingual output helper: UI_LANG/--lang first, else follow NOTIFY_LANG, default zh.
m()  { if [ "${UI_LANG:-${NOTIFY_LANG:-zh}}" = en ]; then printf '%s' "$2"; else printf '%s' "$1"; fi; }
say(){ if [ "${UI_LANG:-${NOTIFY_LANG:-zh}}" = en ]; then printf '%s\n' "$2"; else printf '%s\n' "$1"; fi; }

usage() {
  if [ "${UI_LANG:-${NOTIFY_LANG:-zh}}" = en ]; then
    cat <<'EOF'
Usage: security-update-notify [--test-ok] [--test-reboot] [--no-dedupe] [--doctor] [--check-upgrade] [--upgrade] [--lang zh|en] [--version]

Checks OS backend reboot/service-restart state, then sends Telegram alerts.
EOF
  else
    cat <<'EOF'
用法: security-update-notify [--test-ok] [--test-reboot] [--no-dedupe] [--doctor] [--check-upgrade] [--upgrade] [--lang zh|en] [--version]

检查系统后端的整机重启/服务重启状态，然后发送 Telegram 提醒。
EOF
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --test-ok) SEND_OK=1; shift ;;
    --test-reboot) TEST_REBOOT=1; shift ;;
    --no-dedupe) NO_DEDUPE=1; shift ;;
    --doctor) DOCTOR=1; shift ;;
    --skip-telegram|--skip-telegram-test) DOCTOR_SKIP_TELEGRAM=1; shift ;;
    --check-upgrade) CHECK_UPGRADE=1; shift ;;
    --upgrade) SELF_UPGRADE=1; shift ;;
    --notify-upgrade-event) UPGRADE_NOTICE=1; shift ;;
    --upgrade-from) [[ -n "${2:-}" ]] || { say "缺少 --upgrade-from 的值" "Missing value for --upgrade-from" >&2; exit 2; }; UPGRADE_FROM="$2"; shift 2 ;;
    --upgrade-to) [[ -n "${2:-}" ]] || { say "缺少 --upgrade-to 的值" "Missing value for --upgrade-to" >&2; exit 2; }; UPGRADE_TO="$2"; shift 2 ;;
    --lang) [[ -n "${2:-}" ]] || { say "缺少 --lang 的值" "Missing value for --lang" >&2; exit 2; }; case "$2" in zh|en) UI_LANG="$2" ;; *) say "无效 --lang（应为 zh 或 en）" "Invalid --lang (expected zh or en)" >&2; exit 2 ;; esac; shift 2 ;;
    --version) echo "security-update-notify $VERSION"; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) say "未知参数: $1" "Unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

latest_release_version() {
  python3 - "$REPO" <<'PY'
import json
import sys
import urllib.request

repo = sys.argv[1]
try:
    with urllib.request.urlopen(f"https://api.github.com/repos/{repo}/releases/latest", timeout=20) as response:
        data = json.load(response)
    tag = str(data.get("tag_name", ""))
    print(tag[1:] if tag.startswith("v") else tag)
except Exception as exc:
    print(exc, file=sys.stderr)
    sys.exit(1)
PY
}

# 判断 $2(latest) 是否严格高于 $1(current)。用 sort -V 处理多段与预发布后缀，
# 避免旧版 awk %08d 截断把 1.7.0.1 当作等于 1.7.0、或把 4 段版本误判为降级。
# Whether $2 (latest) is strictly newer than $1 (current). sort -V handles multi-segment and
# pre-release suffixes, avoiding the old awk %08d truncation that treated 1.7.0.1 as 1.7.0.
is_newer_version() {
  local current="$1" latest="$2"
  [[ -n "$current" && -n "$latest" ]] || return 1
  [[ "$current" != "$latest" ]] || return 1
  [[ "$(printf '%s\n%s\n' "$current" "$latest" | sed 's/^v//' | sort -V | tail -1)" == "$(printf '%s\n' "$latest" | sed 's/^v//')" ]]
}

run_check_upgrade() {
  local latest
  say "当前版本: $VERSION" "Current version: $VERSION"
  say "仓库: $REPO" "Repository: $REPO"
  if ! latest="$(latest_release_version)"; then
    say "无法检查最新版本" "Failed to check latest version" >&2
    return 1
  fi
  say "最新版本: $latest" "Latest version: $latest"
  if [[ "$latest" == "$VERSION" ]]; then
    say "已经是最新版本" "Already up to date"
    return 0
  fi
  if is_newer_version "$VERSION" "$latest"; then
    say "可升级: $VERSION -> $latest" "Upgrade available: $VERSION -> $latest"
    return 0
  fi
  say "本地版本高于 latest release" "Local version is newer than latest release"
  return 0
}

# --check-upgrade / --upgrade 在加载完整配置前就退出；若未显式 --lang，则从 env 文件预读
# NOTIFY_LANG，让这些子命令的显示语言也跟随已安装配置。
# --check-upgrade / --upgrade exit before the full config load; if no explicit --lang, pre-read
# NOTIFY_LANG from the env file so these subcommands' display language follows the installed config.
if [[ -z "${UI_LANG:-}" && -z "${NOTIFY_LANG:-}" && -r "$ENV_FILE" ]]; then
  NOTIFY_LANG="$(sed -n "s/^[[:space:]]*NOTIFY_LANG[[:space:]]*=[[:space:]]*[\"']\{0,1\}\(zh\|en\)[\"']\{0,1\}.*/\1/p" "$ENV_FILE" 2>/dev/null | head -1 || true)"
fi

if [[ "$CHECK_UPGRADE" -eq 1 ]]; then
  run_check_upgrade
  exit $?
fi

download_release_file() {
  # 下载发布文件；优先用 curl，缺失时回退到 python3（运行时已硬依赖 python3）。
  # Download a release file; prefer curl, fall back to python3 (already a hard runtime dependency).
  local url="$1" dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl -fL --retry 3 -o "$dest" "$url"
  else
    python3 - "$url" "$dest" <<'PY'
import shutil, sys, urllib.request
url, dest = sys.argv[1], sys.argv[2]
with urllib.request.urlopen(url, timeout=60) as response, open(dest, "wb") as fh:
    shutil.copyfileobj(response, fh)
PY
  fi
}

run_self_upgrade() {
  # 不再把远程脚本 `curl ... | bash` 直接交给 root 执行；改为直接下载 GitHub 发布包，
  # 校验 sha256，并用本程序内置（pin）的指纹强制校验 GPG 签名（默认 fail-closed），
  # 通过后才运行已校验包内的 install.sh。
  # No longer pipe a remote script into root bash. Instead download the GitHub release directly,
  # verify sha256, and require a GPG signature against the fingerprint pinned in this program
  # (fail-closed by default); only then run install.sh from the verified package.
  local disp; disp="${UI_LANG:-${NOTIFY_LANG:-zh}}"
  if [[ "$(id -u)" -ne 0 ]]; then
    command -v sudo >/dev/null 2>&1 || { say "升级需要 root 权限" "Root privileges are required to upgrade" >&2; exit 1; }
    exec sudo "$0" --upgrade --lang "$disp"
  fi
  local c
  for c in tar sha256sum mktemp python3; do
    command -v "$c" >/dev/null 2>&1 || { say "升级需要命令: $c" "Upgrade requires command: $c" >&2; exit 1; }
  done

  local latest tmp pkg pkgdir url sha_url sig_url expected fpr gpg_home rc
  if ! latest="$(latest_release_version)"; then
    say "无法获取最新版本" "Failed to fetch latest version" >&2
    exit 1
  fi
  [[ "$latest" =~ ^[0-9A-Za-z][0-9A-Za-z._-]*$ ]] || { say "无效的最新版本号: $latest" "Invalid latest version: $latest" >&2; exit 1; }
  if [[ "$latest" != "$VERSION" ]] && ! is_newer_version "$VERSION" "$latest"; then
    say "本地版本 $VERSION 高于或等于最新发布 $latest，不自动升级。" "Local version $VERSION is at or above latest release $latest; not upgrading." >&2
    exit 0
  fi
  if [[ "$latest" == "$VERSION" ]]; then
    say "已经是最新版本 $VERSION" "Already up to date: $VERSION"
    exit 0
  fi

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT
  pkg="security-update-notify-${latest}.tar.gz"
  pkgdir="security-update-notify-${latest}"
  url="https://github.com/${REPO}/releases/download/v${latest}/${pkg}"
  sha_url="${url}.sha256"
  sig_url="${url}.asc"

  say "正在下载并校验发布包: $VERSION -> $latest" "Downloading and verifying release: $VERSION -> $latest"
  download_release_file "$url" "$tmp/$pkg" || { say "下载发布包失败" "Failed to download release" >&2; exit 1; }
  download_release_file "$sha_url" "$tmp/$pkg.sha256" || { say "下载校验文件失败" "Failed to download checksum" >&2; exit 1; }

  expected="$(awk 'NF {print $1; exit}' "$tmp/$pkg.sha256")"
  [[ "$expected" =~ ^[A-Fa-f0-9]{64}$ ]] || { say "无效的校验文件" "Invalid checksum file" >&2; exit 1; }
  ( cd "$tmp" && printf '%s  %s\n' "$expected" "$pkg" | sha256sum -c - ) >/dev/null 2>&1 \
    || { say "sha256 校验失败；拒绝升级" "Checksum verification failed; refusing to upgrade" >&2; exit 1; }

  # 安全解包：拒绝路径穿越与非预期顶层目录。
  # Safe extraction: reject path traversal and unexpected top-level directories.
  local entry
  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    case "$entry" in
      /*|../*|*/../*|*/..|..) say "压缩包中存在不安全路径: $entry" "Unsafe path in archive: $entry" >&2; exit 1 ;;
    esac
    case "$entry" in
      "$pkgdir"|"$pkgdir/"|"$pkgdir"/*) ;;
      *) say "压缩包中存在非预期路径: $entry" "Unexpected path in archive: $entry" >&2; exit 1 ;;
    esac
  done < <(tar -tzf "$tmp/$pkg")
  ( cd "$tmp" && tar --no-same-owner -xzf "$pkg" ) || { say "解包失败" "Extraction failed" >&2; exit 1; }

  # GPG 签名校验：用包内公钥，但强制其指纹等于本程序 pin 的指纹（fail-closed）。
  # GPG verification: import the bundled key but require its fingerprint to equal the one pinned here (fail-closed).
  if command -v gpg >/dev/null 2>&1 && download_release_file "$sig_url" "$tmp/$pkg.asc" 2>/dev/null; then
    [[ -s "$tmp/$pkgdir/files/release-signing.pub.asc" ]] || { say "发布包缺少签名公钥；拒绝升级" "Release is missing the signing public key; refusing to upgrade" >&2; exit 1; }
    gpg_home="$tmp/gnupg"
    mkdir -p "$gpg_home"; chmod 700 "$gpg_home"
    GNUPGHOME="$gpg_home" gpg --batch --import "$tmp/$pkgdir/files/release-signing.pub.asc" >/dev/null 2>&1 \
      || { say "导入签名公钥失败；拒绝升级" "Failed to import signing public key; refusing to upgrade" >&2; exit 1; }
    fpr="$(GNUPGHOME="$gpg_home" gpg --batch --with-colons --list-keys 2>/dev/null | awk -F: '$1=="fpr"{print $10; exit}')"
    [[ -n "$RELEASE_SIGNING_FINGERPRINT" ]] || { say "未配置签名指纹；拒绝升级" "No signing fingerprint configured; refusing to upgrade" >&2; exit 1; }
    [[ "$fpr" == "$RELEASE_SIGNING_FINGERPRINT" ]] || { say "签名公钥指纹不匹配（期望 $RELEASE_SIGNING_FINGERPRINT，实际 ${fpr:-none}）；拒绝升级" "Signing key fingerprint mismatch; refusing to upgrade" >&2; exit 1; }
    GNUPGHOME="$gpg_home" gpg --batch --verify "$tmp/$pkg.asc" "$tmp/$pkg" >/dev/null 2>&1 \
      || { say "签名校验失败；拒绝升级" "Signature verification failed; refusing to upgrade" >&2; exit 1; }
    say "签名校验通过 (${RELEASE_SIGNING_FINGERPRINT})" "Signature verified (${RELEASE_SIGNING_FINGERPRINT})"
  elif [[ "$UPGRADE_ALLOW_UNSIGNED" == "1" ]]; then
    say "警告：未校验 GPG 签名（SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED=1），仅校验 sha256。" "WARNING: skipping GPG verification (SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED=1); sha256 only." >&2
  else
    say "缺少 gpg 或发布签名，且未设置 SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED=1；为安全起见拒绝升级。" "Missing gpg or release signature and SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED is not set; refusing to upgrade for safety." >&2
    exit 1
  fi

  [[ -f "$tmp/$pkgdir/install.sh" ]] || { say "发布包缺少 install.sh" "Release is missing install.sh" >&2; exit 1; }
  chmod 0755 "$tmp/$pkgdir/install.sh" 2>/dev/null || true
  say "正在以已校验的发布包升级..." "Upgrading from the verified release..."
  cd "$tmp/$pkgdir" || { say "进入解包目录失败" "Failed to enter extracted directory" >&2; exit 1; }
  rc=0
  SECURITY_UPDATE_NOTIFY_UPGRADE=1 ./install.sh --non-interactive -y --lang "$disp" || rc=$?
  cd / || true
  rm -rf "$tmp"
  trap - EXIT
  exit "$rc"
}

if [[ "$SELF_UPGRADE" -eq 1 ]]; then
  run_self_upgrade
fi

mkdir -p "$STATE_DIR"
chmod 0750 "$STATE_DIR" 2>/dev/null || true
exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

log_event() {
  local line="$1"
  mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S %z')" "$line" >>"$LOG_FILE" 2>/dev/null || true
}

load_config_file() {
  local file="$1" line key value
  [[ -r "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" == export\ * ]] && line="${line#export }"
    [[ "$line" == *"="* ]] || { say "配置行无效: $file" "Invalid config line in $file" >&2; return 2; }
    key="${line%%=*}"
    value="${line#*=}"
    key="${key//[[:space:]]/}"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || { say "配置键无效: $file: $key" "Invalid config key in $file: $key" >&2; return 2; }
    value="${value#${value%%[![:space:]]*}}"
    value="${value%${value##*[![:space:]]}}"
    if [[ "$value" != \"* && "$value" != \'* ]]; then
      value="${value%%[[:space:]]#*}"
      value="${value%${value##*[![:space:]]}}"
    fi
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value="${value:1:${#value}-2}"; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value="${value:1:${#value}-2}"; fi
    case "$key" in
      TELEGRAM_BOT_TOKEN|TELEGRAM_CHAT_ID|HOST_LABEL|PUBLIC_IP|INCLUDE_PUBLIC_IP|NOTIFY_OK|NOTIFY_UPGRADE|DEDUP_MODE|DEDUP_INTERVAL_DAYS|NOTIFY_LANG|BACKEND|CONFIG_VERSION)
        printf -v "$key" '%s' "$value"
        ;;
      *) say "配置键不支持: $file: $key" "Unsupported config key in $file: $key" >&2; return 2 ;;
    esac
  done <"$file"
}

telegram_get_me() {
  printf '%s' "${TELEGRAM_BOT_TOKEN:-}" | python3 -c '
import json, re, sys, urllib.request

token = sys.stdin.read()
if not token:
    print("缺少 TELEGRAM_BOT_TOKEN / missing TELEGRAM_BOT_TOKEN", file=sys.stderr)
    sys.exit(2)
if not re.match(r"^\d+:[A-Za-z0-9_-]+$", token):
    print("TELEGRAM_BOT_TOKEN 格式无效 / invalid TELEGRAM_BOT_TOKEN format", file=sys.stderr)
    sys.exit(2)

url = f"https://api.telegram.org/bot{token}/getMe"
try:
    with urllib.request.urlopen(url, timeout=20) as response:
        body = response.read().decode("utf-8", "replace")
except Exception as exc:
    print(exc, file=sys.stderr)
    sys.exit(1)

print(body)
try:
    ok = bool(json.loads(body).get("ok"))
except Exception:
    ok = False
sys.exit(0 if ok else 1)
'
}

telegram_send_message() {
  local text="$1"
  printf '%s\0%s\0%s' "${TELEGRAM_BOT_TOKEN:-}" "${TELEGRAM_CHAT_ID:-}" "$text" | python3 -c '
import json, re, sys, time, urllib.parse, urllib.request, urllib.error

payload = sys.stdin.buffer.read().split(b"\0", 2)
token = payload[0].decode("utf-8", "replace") if len(payload) > 0 else ""
chat_id = payload[1].decode("utf-8", "replace") if len(payload) > 1 else ""
text = payload[2].decode("utf-8", "replace") if len(payload) > 2 else ""
if not token or not chat_id:
    print("缺少 Telegram token 或 chat id / missing Telegram token or chat id", file=sys.stderr)
    sys.exit(2)
if not re.match(r"^\d+:[A-Za-z0-9_-]+$", token):
    print("TELEGRAM_BOT_TOKEN 格式无效 / invalid TELEGRAM_BOT_TOKEN format", file=sys.stderr)
    sys.exit(2)
# Telegram sendMessage 上限约 4096 字符；超长则截断，避免必然失败。
# Telegram sendMessage caps around 4096 chars; truncate over-long bodies to avoid a guaranteed failure.
if len(text) > 4096:
    text = text[:4000] + "\n…(truncated)"

url = f"https://api.telegram.org/bot{token}/sendMessage"
data = urllib.parse.urlencode({
    "chat_id": chat_id,
    "text": text,
    "disable_web_page_preview": "true",
}).encode()

last_error = ""
for attempt in range(3):
    try:
        with urllib.request.urlopen(url, data=data, timeout=30) as response:
            body = response.read().decode("utf-8", "replace")
        try:
            ok = bool(json.loads(body).get("ok"))
        except Exception:
            ok = False
        if ok:
            sys.exit(0)
        # API returned ok=false (bad chat id / bot blocked / etc.) — not transient, do not retry.
        last_error = body
        break
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", "replace")
        last_error = "HTTP " + str(exc.code) + ": " + body[:300]
        # Only 429 (rate limit) and 5xx are worth retrying; other 4xx are permanent.
        if exc.code not in (429, 500, 502, 503, 504):
            break
    except Exception as exc:
        last_error = str(exc)
    if attempt < 2:
        time.sleep(1)

print(last_error or "Telegram 通知发送失败 / Telegram notification failed", file=sys.stderr)
sys.exit(1)
'
}

load_config_file "$ENV_FILE" || exit $?

HOST="${HOST_LABEL:-$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo unknown)}"
INCLUDE_PUBLIC_IP="${INCLUDE_PUBLIC_IP:-1}"
case "${INCLUDE_PUBLIC_IP,,}" in
  1|true|yes|on) INCLUDE_PUBLIC_IP=1 ;;
  0|false|no|off) INCLUDE_PUBLIC_IP=0 ;;
  *) INCLUDE_PUBLIC_IP=1 ;;
esac

get_public_ip() {
  if [[ -n "${PUBLIC_IP:-}" ]]; then
    printf '%s\n' "$PUBLIC_IP"
    return
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    printf 'unknown\n'
    return
  fi
  python3 - <<'PY'
import ipaddress
import sys
import urllib.request

urls = ("https://api.ipify.org", "https://ifconfig.me/ip")
for url in urls:
    try:
        with urllib.request.urlopen(url, timeout=5) as response:
            ip = response.read(128).decode("utf-8", "replace").strip().split()[0]
        ipaddress.ip_address(ip)
    except Exception:
        continue
    print(ip)
    sys.exit(0)
print("unknown")
PY
}
PUBLIC_IP_VALUE=""
if [[ "$INCLUDE_PUBLIC_IP" -eq 1 ]]; then
  PUBLIC_IP_VALUE="$(get_public_ip)"
fi
PUBLIC_IP_LINE_ZH=""
PUBLIC_IP_LINE_EN=""
if [[ "$INCLUDE_PUBLIC_IP" -eq 1 ]]; then
  PUBLIC_IP_LINE_ZH="\n公网 IP：$PUBLIC_IP_VALUE"
  PUBLIC_IP_LINE_EN="\nPublic IP: $PUBLIC_IP_VALUE"
fi
OS_RELEASE_ID=""
OS_RELEASE_ID_LIKE=""
OS_RELEASE_PRETTY_NAME="unknown"
if [[ -r /etc/os-release ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    case "$line" in
      ID=*|ID_LIKE=*|PRETTY_NAME=*)
        key="${line%%=*}"
        value="${line#*=}"
        if [[ "$value" == \"*\" && "$value" == *\" ]]; then value="${value:1:${#value}-2}"; fi
        if [[ "$value" == \'*\' && "$value" == *\' ]]; then value="${value:1:${#value}-2}"; fi
        case "$key" in
          ID) OS_RELEASE_ID="$value" ;;
          ID_LIKE) OS_RELEASE_ID_LIKE="$value" ;;
          PRETTY_NAME) OS_RELEASE_PRETTY_NAME="$value" ;;
        esac
        ;;
    esac
  done </etc/os-release
fi
OS="$OS_RELEASE_PRETTY_NAME"
KERNEL="$(uname -r 2>/dev/null || echo unknown)"
NOW="$(date '+%Y-%m-%d %H:%M:%S %Z')"
BACKEND="${BACKEND:-auto}"
NOTIFY_LANG="${NOTIFY_LANG:-zh}"
case "$NOTIFY_LANG" in zh|en) ;; *) NOTIFY_LANG="zh" ;; esac

if [[ "$BACKEND" == "auto" ]]; then
  case "${OS_RELEASE_ID:-}" in
    debian|ubuntu) BACKEND="apt" ;;
    rhel|rocky|almalinux|fedora|centos|amzn) BACKEND="dnf" ;;
    *) BACKEND="unknown" ;;
  esac
  # 衍生发行版（Oracle Linux、CloudLinux 等）精确 ID 未命中时，用 ID_LIKE 兜底。
  # Fall back to ID_LIKE for derivatives (Oracle Linux, CloudLinux, ...) when the exact ID does not match.
  if [[ "$BACKEND" == "unknown" && -n "$OS_RELEASE_ID_LIKE" ]]; then
    case " $OS_RELEASE_ID_LIKE " in
      *" debian "*|*" ubuntu "*) BACKEND="apt" ;;
      *" rhel "*|*" fedora "*|*" centos "*) BACKEND="dnf" ;;
    esac
  fi
fi

run_doctor() {
  local ok=1
  echo "security-update-notify $VERSION"
  say "配置文件: $ENV_FILE" "Config: $ENV_FILE"
  [[ -r "$ENV_FILE" ]] && say "正常：配置可读" "OK config readable" || { say "失败：配置不可读" "FAIL config not readable"; ok=0; }
  say "后端: $BACKEND" "Backend: $BACKEND"
  say "主机: $HOST" "Host: $HOST"
  [[ "$INCLUDE_PUBLIC_IP" -eq 1 ]] && say "公网 IP: $PUBLIC_IP_VALUE" "Public IP: $PUBLIC_IP_VALUE"
  say "系统: $OS" "OS: $OS"
  say "内核: $KERNEL" "Kernel: $KERNEL"
  if [[ -d /run/systemd/system ]] && command -v systemctl >/dev/null 2>&1; then
    say "正常：systemd 存在" "OK systemd present"
    systemctl is-enabled security-update-notify.timer >/dev/null 2>&1 && say "正常：timer 已启用" "OK timer enabled" || { say "警告：timer 未启用" "WARN timer not enabled"; ok=0; }
    systemctl list-timers security-update-notify.timer --no-pager 2>/dev/null || true
  else
    say "失败：systemd 不可用" "FAIL systemd unavailable"; ok=0
  fi
  case "$BACKEND" in
    apt)
      for c in apt-get dpkg needrestart; do command -v "$c" >/dev/null 2>&1 && say "正常：命令存在 $c" "OK command $c" || { say "失败：缺少命令 $c" "FAIL missing command $c"; ok=0; }; done
      dpkg -s unattended-upgrades >/dev/null 2>&1 && say "正常：unattended-upgrades 已安装" "OK unattended-upgrades installed" || { say "失败：缺少 unattended-upgrades" "FAIL unattended-upgrades missing"; ok=0; }
      ;;
    dnf)
      command -v dnf >/dev/null 2>&1 && say "正常：命令存在 dnf" "OK command dnf" || command -v yum >/dev/null 2>&1 && say "正常：命令存在 yum" "OK command yum" || { say "失败：缺少 dnf/yum" "FAIL missing dnf/yum"; ok=0; }
      command -v needs-restarting >/dev/null 2>&1 && say "正常：命令存在 needs-restarting" "OK command needs-restarting" || { say "失败：缺少 needs-restarting" "FAIL missing needs-restarting"; ok=0; }
      systemctl is-enabled dnf-automatic.timer >/dev/null 2>&1 && say "正常：dnf-automatic.timer 已启用" "OK dnf-automatic.timer enabled" || say "警告：dnf-automatic.timer 未启用" "WARN dnf-automatic.timer not enabled"
      ;;
    *) say "失败：不支持的后端 $BACKEND" "FAIL unsupported backend $BACKEND"; ok=0 ;;
  esac
  if [[ "$DOCTOR_SKIP_TELEGRAM" -eq 1 ]]; then
    say "跳过：Telegram 联通性检查" "SKIP Telegram connectivity check"
  elif [[ -n "${TELEGRAM_BOT_TOKEN:-}" && -n "${TELEGRAM_CHAT_ID:-}" ]]; then
    say "正常：Telegram 配置存在" "OK Telegram config present"
    if telegram_get_me >/dev/null; then
      say "正常：Telegram Bot Token 可用" "OK Telegram bot token works"
    else
      say "失败：Telegram getMe 失败" "FAIL Telegram getMe failed"; ok=0
    fi
  else
    say "失败：Telegram 配置缺失" "FAIL Telegram config missing"; ok=0
  fi
  [[ "$ok" -eq 1 ]] || return 1
}

if [[ "$DOCTOR" -eq 1 ]]; then
  run_doctor
  exit $?
fi

if [[ "$UPGRADE_NOTICE" -eq 1 ]]; then
  from="${UPGRADE_FROM:-unknown}"
  to="${UPGRADE_TO:-$VERSION}"
  zh_msg="✅ SUN 已升级\n\n主机：$HOST${PUBLIC_IP_LINE_ZH}\n版本：$from → $to\n时间：$NOW\n\n升级后自检已完成。"
  en_msg="✅ SUN upgraded\n\nHost: $HOST${PUBLIC_IP_LINE_EN}\nVersion: $from → $to\nTime: $NOW\n\nPost-upgrade self-check completed."
  if [[ "${NOTIFY_UPGRADE:-0}" == "1" ]]; then
    if [[ "$NOTIFY_LANG" == "en" ]]; then msg="$en_msg"; else msg="$zh_msg"; fi
    msg="${msg//\\n/$'\n'}"
    telegram_send_message "$msg"
  fi
  exit 0
fi

reboot_required=0
reboot_pkgs=""
restart_attention=0
restart_summary=""
restart_signal=""
update_summary=""

check_apt() {
  if [[ "$TEST_REBOOT" -eq 1 ]]; then
    reboot_required=1
    reboot_pkgs=$'linux-image-amd64\nTEST-MODE-no-real-reboot'
    restart_summary=$'NEEDRESTART-VER: test\nNEEDRESTART-KCUR: test-current\nNEEDRESTART-KEXP: test-expected\nNEEDRESTART-KSTA: 3\nNEEDRESTART-SVC: ssh.service'
    restart_attention=1
    return
  fi
  if [[ -f /var/run/reboot-required ]]; then
    reboot_required=1
    reboot_pkgs="$(cat /var/run/reboot-required.pkgs 2>/dev/null | sed '/^$/d' | sort -u)"
  fi
  if command -v needrestart >/dev/null 2>&1; then
    # 只取 stdout（批处理字段）；stderr 的瞬时告警不进摘要/哈希，避免污染去重。
    # Take stdout only (batch fields); stderr's transient warnings stay out of the summary/hash.
    restart_summary="$(needrestart -b 2>/dev/null || true)"
    local kcur kexp ksta
    kcur="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KCUR:/{print $2; exit}')"
    kexp="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KEXP:/{print $2; exit}')"
    ksta="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KSTA:/{print $2; exit}')"
    # 关注信号只取：内核确实更换（KCUR!=KEXP）、KSTA 为 2/3（ABI/版本升级待重启），以及
    # 需要重启的 systemd 服务（SVC）。不再因 KSTA=0（未知）或 SESS/AUX（用户会话，含管理员
    # 自己的 SSH 登录）误报——这些只在摘要里作信息展示。与 dnf 端 needs-restarting -s 的策略一致。
    # Attention only from: a real kernel change (KCUR!=KEXP), KSTA 2/3 (ABI/version upgrade pending),
    # and systemd services needing restart (SVC). No longer triggered by KSTA=0 (unknown) or SESS/AUX
    # (user sessions incl. the admin's own SSH login) — those are shown in the summary only. Parity
    # with the dnf needs-restarting -s policy.
    [[ -n "$kcur" && -n "$kexp" && "$kcur" != "$kexp" ]] && restart_attention=1
    [[ "$ksta" == "2" || "$ksta" == "3" ]] && restart_attention=1
    printf '%s\n' "$restart_summary" | grep -Eq '^NEEDRESTART-SVC:' && restart_attention=1
    # 去重哈希用的稳定信号：只含决策相关、跨周期稳定的字段（内核 + 服务），不含瞬时输出。
    # Stable signal for the dedup hash: only decision-relevant, cross-run-stable fields (kernel + services).
    restart_signal="$(printf 'KCUR=%s\nKEXP=%s\nKSTA=%s\n%s\n' "$kcur" "$kexp" "$ksta" \
      "$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-SVC:/{print $2}' | sed '/^$/d' | sort -u)")"
  else
    restart_summary="needrestart 命令不存在 / needrestart command not found"
  fi
}

check_dnf() {
  if [[ "$TEST_REBOOT" -eq 1 ]]; then
    reboot_required=1
    reboot_pkgs=$'kernel\nTEST-MODE-no-real-reboot'
    restart_summary=$'needs-restarting -r:\nReboot is required to ensure that your system benefits from these updates.\n\nneeds-restarting -s:\ntest-service.service'
    restart_attention=1
    return
  fi
  if command -v needs-restarting >/dev/null 2>&1; then
    local nr_r rc nr_svc nr_has_s
    rc=0
    nr_r="$(needs-restarting -r 2>&1)" || rc=$?
    # 探测本机 needs-restarting 是否支持 -s（仅列服务）。老版 dnf-utils 不支持时，退回“仅按
    # 整机重启判断”（保守、不误报），并在摘要里给出可见提示，而不是静默丢失服务检测。
    # Probe whether this needs-restarting supports -s (services only). On older dnf-utils that lack it,
    # degrade to reboot-only (conservative, no false alerts) with a visible note in the summary,
    # rather than silently losing service-restart detection.
    nr_has_s=0
    needs-restarting --help 2>&1 | grep -q -- '-s' && nr_has_s=1
    # 优先按 needs-restarting -r 的输出文案判断是否需要整机重启，避免把命令本身的报错
    # （权限不足、异常退出等任何非零码）误判为“需要重启”。退出码 1 是其表示“需要重启”的
    # 约定值，仅作为文案无法匹配时的回退；其它非零码视为命令出错，不作为重启信号。
    # Decide a full reboot from needs-restarting -r's message first, so that command errors
    # (insufficient privileges, crashes, any non-zero code) are not mistaken for "reboot required".
    # Exit code 1 is its documented "reboot required" signal and is used only as a fallback when the
    # message does not match; other non-zero codes are treated as errors, not a reboot signal.
    if printf '%s\n' "$nr_r" | grep -qiE 'reboot is required'; then
      reboot_required=1
    elif printf '%s\n' "$nr_r" | grep -qiE 'reboot should not be necessary|no core libraries'; then
      reboot_required=0
    elif [[ "$rc" -eq 1 ]]; then
      reboot_required=1
    fi
    # 只用“需要重启的 systemd 服务”（needs-restarting -s）作为关注信号。裸 needs-restarting 会
    # 列出所有仍在使用旧库的普通进程，在长期运行的系统上几乎总是非空，会造成每个周期都误报。
    # Use only systemd services that need restarting (needs-restarting -s) as the attention signal.
    # Bare needs-restarting lists every process still using an outdated library and is almost always
    # non-empty on long-running systems, which would otherwise raise a false alert every cycle.
    if [[ "$nr_has_s" -eq 1 ]]; then
      nr_svc="$(needs-restarting -s 2>/dev/null | sed '/^$/d' | sort -u || true)"
    else
      nr_svc=""
    fi
    if printf '%s\n' "$nr_svc" | sed '/^$/d' | grep -q .; then
      restart_attention=1
    fi
    if [[ "$nr_has_s" -eq 1 ]]; then
      restart_summary="needs-restarting -r:\n${nr_r}\n\nneeds-restarting -s:\n${nr_svc}"
    else
      restart_summary="needs-restarting -r:\n${nr_r}\n\n此版本 needs-restarting 不支持 -s，仅按整机重启判断。/ This needs-restarting lacks -s; reboot-only detection."
    fi
    # 稳定去重信号：服务列表（reboot_required 已单独进哈希）。
    # Stable dedup signal: the service list (reboot_required is hashed separately).
    restart_signal="$nr_svc"
  else
    restart_summary="needs-restarting 命令不存在；请安装 dnf-utils/yum-utils / needs-restarting command not found; install dnf-utils/yum-utils"
  fi
  if command -v dnf >/dev/null 2>&1; then
    update_summary="$(dnf -q updateinfo list security updates 2>/dev/null | sed -n '1,40p' || true)"
  fi
  # 只取像“包名.架构”的行作为相关包，过滤表头/汇总等杂质（$NF 直接取会混入噪声）。
  # Keep only rows whose last field looks like name.arch (filter header/summary noise that $NF would leak).
  reboot_pkgs="$(printf '%s\n' "$update_summary" | awk '$NF ~ /\.(x86_64|noarch|aarch64|i686|ppc64le|s390x)$/ {print $NF}' | sed '/^$/d' | sort -u | sed -n '1,40p')"
}

format_restart_summary() {
  local lang="$1" summary kcur kexp ksta services service_count other_count s_unsupported
  summary="${restart_summary//\\n/$'\n'}"
  case "$BACKEND" in
    apt)
      kcur="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KCUR:/{print $2; exit}')"
      kexp="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KEXP:/{print $2; exit}')"
      ksta="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KSTA:/{print $2; exit}')"
      services="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-SVC:/{print $2}' | sed '/^$/d' | sort -u)"
      service_count="$(printf '%s\n' "$services" | sed '/^$/d' | wc -l | tr -d ' ')"
      other_count="$(printf '%s\n' "$summary" | grep -Ec '^NEEDRESTART-(AUX|SESS|UCSTA|UCCUR|UCEXP):' || true)"

      if [[ "$lang" == "en" ]]; then
        [[ -n "$kcur" || -n "$kexp" ]] && printf 'Kernel: current %s, expected %s\n' "${kcur:-unknown}" "${kexp:-unknown}"
        [[ -n "$ksta" ]] && printf 'Kernel status code: %s\n' "$ksta"
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf 'Services to review/restart (%s):\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ... and %s more\n' "$((service_count - 12))"
        fi
        [[ "${other_count:-0}" -gt 0 ]] && printf 'Additional sessions/containers/processes need review. Run needrestart on the server for details.\n'
        [[ -z "$kcur$kexp$services" && "${other_count:-0}" -eq 0 ]] && printf 'No detailed restart list was available. Run needrestart -b on the server for details.\n'
      else
        [[ -n "$kcur" || -n "$kexp" ]] && printf '内核：当前 %s，建议 %s\n' "${kcur:-未知}" "${kexp:-未知}"
        [[ -n "$ksta" ]] && printf '内核状态码：%s\n' "$ksta"
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf '建议评估/重启的服务（%s 个）：\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ……另有 %s 个\n' "$((service_count - 12))"
        fi
        [[ "${other_count:-0}" -gt 0 ]] && printf '另有用户会话、容器或进程需要关注；可在服务器上运行 needrestart 查看详情。\n'
        [[ -z "$kcur$kexp$services" && "${other_count:-0}" -eq 0 ]] && printf '没有拿到详细重启列表；可在服务器上运行 needrestart -b 查看详情。\n'
      fi
      ;;
    dnf)
      services="$(printf '%s\n' "$summary" | awk '/^needs-restarting -s:$/{f=1; next} /^needs-restarting/{f=0} f && NF {print}' | sed '/^$/d' | sort -u)"
      service_count="$(printf '%s\n' "$services" | sed '/^$/d' | wc -l | tr -d ' ')"
      s_unsupported=0
      [[ "$summary" == *"lacks -s"* || "$summary" == *"不支持 -s"* ]] && s_unsupported=1
      if [[ "$lang" == "en" ]]; then
        [[ "$reboot_required" -eq 1 ]] && printf 'Full reboot: required by needs-restarting -r\n'
        [[ "$s_unsupported" -eq 1 ]] && printf 'Note: this needs-restarting lacks -s; per-service detection unavailable (reboot-only).\n'
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf 'Services to review/restart (%s):\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ... and %s more\n' "$((service_count - 12))"
        elif [[ "$reboot_required" -ne 1 && "$s_unsupported" -eq 0 ]]; then
          printf 'No services were reported as needing a restart. Run needs-restarting on the server for details.\n'
        fi
      else
        [[ "$reboot_required" -eq 1 ]] && printf '整机重启：needs-restarting -r 判断为需要\n'
        [[ "$s_unsupported" -eq 1 ]] && printf '提示：此版本 needs-restarting 不支持 -s，无法按服务检测（仅整机重启）。\n'
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf '建议评估/重启的服务（%s 个）：\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ……另有 %s 个\n' "$((service_count - 12))"
        elif [[ "$reboot_required" -ne 1 && "$s_unsupported" -eq 0 ]]; then
          printf '没有服务被报告需要重启；可在服务器上运行 needs-restarting 查看详情。\n'
        fi
      fi
      ;;
  esac
}

case "$BACKEND" in
  apt) check_apt ;;
  dnf) check_dnf ;;
  *) say "不支持的后端: $BACKEND" "Unsupported backend: $BACKEND" >&2; exit 2 ;;
esac

if [[ "$reboot_required" -eq 0 && "$restart_attention" -eq 0 ]]; then
  log_event "check ok backend=$BACKEND host=$HOST no_attention=1"
  if [[ "$SEND_OK" -eq 1 || "${NOTIFY_OK:-0}" == "1" ]]; then
    zh_msg="✅ 安全更新检查正常\n\n主机：$HOST${PUBLIC_IP_LINE_ZH}\n系统：$OS\n后端：$BACKEND\n当前内核：$KERNEL\n时间：$NOW\n\n没有发现整机重启或服务/进程重启需要关注的问题。"
    en_msg="✅ Security update check OK\n\nHost: $HOST${PUBLIC_IP_LINE_EN}\nOS: $OS\nBackend: $BACKEND\nCurrent kernel: $KERNEL\nTime: $NOW\n\nNo reboot or service/process restart requiring attention was detected."
    if [[ "$NOTIFY_LANG" == "en" ]]; then
      msg="$en_msg"
    else
      msg="$zh_msg"
    fi
  else
    log_event "silent ok backend=$BACKEND host=$HOST"
    exit 0
  fi
else
  pkgs_zh="无"
  pkgs_en="None"
  if [[ -n "$reboot_pkgs" ]]; then
    pkgs_zh="$reboot_pkgs"
    pkgs_en="$reboot_pkgs"
  fi
  rs_zh="$(format_restart_summary zh | sed -n '1,80p')"
  rs_en="$(format_restart_summary en | sed -n '1,80p')"
  reboot_text_zh="$([[ "$reboot_required" -eq 1 ]] && echo '需要' || echo '暂不需要')"
  reboot_text_en="$([[ "$reboot_required" -eq 1 ]] && echo 'Required' || echo 'Not required for now')"
  zh_msg="⚠️ 安全更新后需要处理\n\n主机：$HOST${PUBLIC_IP_LINE_ZH}\n系统：$OS\n后端：$BACKEND\n当前内核：$KERNEL\n时间：$NOW\n\n整机重启：$reboot_text_zh\n相关包/安全更新：\n$pkgs_zh\n\n重启检测摘要：\n$rs_zh\n\n建议：请在方便的维护窗口 SSH 登录该服务器后手动执行 reboot；如只是服务需要重启，可先评估并重启对应服务。"
  en_msg="⚠️ Security update action required\n\nHost: $HOST${PUBLIC_IP_LINE_EN}\nOS: $OS\nBackend: $BACKEND\nCurrent kernel: $KERNEL\nTime: $NOW\n\nFull reboot: $reboot_text_en\nRelated packages/security updates:\n$pkgs_en\n\nRestart detection summary:\n$rs_en\n\nRecommendation: SSH into this server during a suitable maintenance window and run reboot if a full reboot is required. If only services need restarting, review them first and restart the affected services manually."
  if [[ "$NOTIFY_LANG" == "en" ]]; then
    msg="$en_msg"
  else
    msg="$zh_msg"
  fi
fi
msg="${msg//\\n/$'\n'}"


# 去重哈希只基于决策相关、跨周期稳定的字段：排除 PUBLIC_IP（动态出口 IP 会变）与含瞬时输出
# 的原始摘要，改用 restart_signal（规范化的内核/服务信号），避免同一状态被反复发送。
# Dedup hash uses only decision-relevant, cross-run-stable fields: excludes PUBLIC_IP (dynamic egress
# IP) and the raw summary (transient output), using restart_signal (normalized kernel/service signal).
alert_hash="$(printf '%s\n%s\n%s\n%s\n%s\n%s\n%s\n' "$HOST" "$BACKEND" "$NOTIFY_LANG" "$reboot_required" "$reboot_pkgs" "$restart_attention" "$restart_signal" | sha256sum | awk '{print $1}')"
last_hash="$(cat "$STATE_FILE" 2>/dev/null || true)"
last_sent="$(cat "$STATE_TIME_FILE" 2>/dev/null || echo 0)"
now_epoch="$(date +%s)"
dedup_mode="${DEDUP_MODE:-interval}"
dedup_days="${DEDUP_INTERVAL_DAYS:-3}"
[[ "$dedup_days" =~ ^[0-9]+$ && "$dedup_days" -ge 1 ]] || dedup_days=3
should_send=1
if [[ "$NO_DEDUPE" -ne 1 && "$alert_hash" == "$last_hash" ]]; then
  case "$dedup_mode" in
    always) should_send=0 ;;
    daily)
      last_day="$(date -d "@$last_sent" +%F 2>/dev/null || echo '')"
      today="$(date +%F)"
      [[ "$last_day" == "$today" ]] && should_send=0
      ;;
    interval|*)
      interval_seconds=$(( dedup_days * 86400 ))
      if [[ "$last_sent" =~ ^[0-9]+$ ]] && (( now_epoch - last_sent < interval_seconds )); then should_send=0; fi
      ;;
  esac
fi
if [[ "$should_send" -eq 0 ]]; then
  log_event "dedup suppressed backend=$BACKEND host=$HOST mode=$dedup_mode hash=$alert_hash"
  exit 0
fi

if [[ -z "${TELEGRAM_BOT_TOKEN:-}" || -z "${TELEGRAM_CHAT_ID:-}" ]]; then
  say "在 $ENV_FILE 中缺少 TELEGRAM_BOT_TOKEN 或 TELEGRAM_CHAT_ID" "Missing TELEGRAM_BOT_TOKEN or TELEGRAM_CHAT_ID in $ENV_FILE" >&2
  exit 2
fi

if telegram_send_message "$msg"; then
  printf '%s\n' "$alert_hash" >"$STATE_FILE"
  printf '%s\n' "$now_epoch" >"$STATE_TIME_FILE"
  log_event "telegram sent backend=$BACKEND host=$HOST reboot_required=$reboot_required restart_attention=$restart_attention hash=$alert_hash"
else
  log_event "telegram failed backend=$BACKEND host=$HOST"
  say "Telegram 通知发送失败" "Telegram notification failed" >&2
  exit 1
fi
