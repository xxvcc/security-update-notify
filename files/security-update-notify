#!/usr/bin/env bash
# 故意不加 -e：后端检测命令（needrestart、needs-restarting）的非零退出码不应中断通知流程。
# Intentionally omit -e: non-zero exits from backend detection commands must not abort the notification flow.
set -uo pipefail
# 固定 locale，让 needrestart/needs-restarting 文案匹配、sort -V、awk/sed 字段解析在任何
# 系统语言下都确定（仅影响解析；消息正文是原始 UTF-8 字节，不受影响）。
# Pin the locale so message matching, sort -V and awk/sed field parsing are deterministic under
# any system language (parsing only; message bodies are raw UTF-8 bytes and are unaffected).
export LC_ALL=C

ENV_FILE="${SECURITY_UPDATE_NOTIFY_ENV:-/etc/security-update-notify/telegram.env}"
STATE_DIR="/var/lib/security-update-notify"
STATE_FILE="$STATE_DIR/last-alert.sha256"
STATE_TIME_FILE="$STATE_DIR/last-alert.sent_at"
LOCK_FILE="/run/security-update-notify.lock"
VERSION="2.0.1"
REPO="xxvcc/security-update-notify"
RELEASE_SIGNING_FINGERPRINT="C678256ACBFC6491BF5076655F3AE24999921FFC"
UPGRADE_ALLOW_UNSIGNED="${SECURITY_UPDATE_NOTIFY_UPGRADE_ALLOW_UNSIGNED:-0}"
LOG_FILE="/var/log/security-update-notify.log"
TEST_REBOOT=0
SEND_OK=0
NO_DEDUPE=0
DOCTOR=0
DOCTOR_SKIP_TELEGRAM=0
CHECK_UPGRADE=0
SELF_UPGRADE=0
UPGRADE_NOTICE=0
UPGRADE_FROM=""
UPGRADE_TO=""
UI_LANG="${UI_LANG:-${SUN_LANG:-}}"

# 双语输出助手：UI_LANG/--lang 优先，否则跟随 NOTIFY_LANG，默认 zh。
# Bilingual output helper: UI_LANG/--lang first, else follow NOTIFY_LANG, default zh.
m()  { if [ "${UI_LANG:-${NOTIFY_LANG:-zh}}" = en ]; then printf '%s' "$2"; else printf '%s' "$1"; fi; }
say(){ if [ "${UI_LANG:-${NOTIFY_LANG:-zh}}" = en ]; then printf '%s\n' "$2"; else printf '%s\n' "$1"; fi; }

usage() {
  if [ "${UI_LANG:-${NOTIFY_LANG:-zh}}" = en ]; then
    cat <<'EOF'
Usage: security-update-notify [--test-ok] [--test-reboot] [--no-dedupe] [--doctor] [--check-upgrade] [--upgrade] [--lang zh|en] [--version]

Checks OS backend reboot/service-restart state, then sends Telegram alerts.
EOF
  else
    cat <<'EOF'
用法: security-update-notify [--test-ok] [--test-reboot] [--no-dedupe] [--doctor] [--check-upgrade] [--upgrade] [--lang zh|en] [--version]

检查系统后端的整机重启/服务重启状态，然后发送 Telegram 提醒。
EOF
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --test-ok) SEND_OK=1; shift ;;
    --test-reboot) TEST_REBOOT=1; shift ;;
    --no-dedupe) NO_DEDUPE=1; shift ;;
    --doctor) DOCTOR=1; shift ;;
    --skip-telegram|--skip-telegram-test) DOCTOR_SKIP_TELEGRAM=1; shift ;;
    --check-upgrade) CHECK_UPGRADE=1; shift ;;
    --upgrade) SELF_UPGRADE=1; shift ;;
    --notify-upgrade-event) UPGRADE_NOTICE=1; shift ;;
    --upgrade-from) [[ -n "${2:-}" ]] || { say "缺少 --upgrade-from 的值" "Missing value for --upgrade-from" >&2; exit 2; }; UPGRADE_FROM="$2"; shift 2 ;;
    --upgrade-to) [[ -n "${2:-}" ]] || { say "缺少 --upgrade-to 的值" "Missing value for --upgrade-to" >&2; exit 2; }; UPGRADE_TO="$2"; shift 2 ;;
    --lang) [[ -n "${2:-}" ]] || { say "缺少 --lang 的值" "Missing value for --lang" >&2; exit 2; }; case "$2" in zh|en) UI_LANG="$2" ;; *) say "无效 --lang（应为 zh 或 en）" "Invalid --lang (expected zh or en)" >&2; exit 2 ;; esac; shift 2 ;;
    --version) echo "security-update-notify $VERSION"; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) say "未知参数: $1" "Unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

latest_release_version() {
  python3 - "$REPO" <<'PY'
import json
import sys
import urllib.error
import urllib.parse
import urllib.request

# 与 download_release_file 保持一致：拒绝任何非 https 的重定向，请求不可被降级到明文。
# Match download_release_file: refuse any non-https redirect so the request cannot be downgraded to plaintext.
class HTTPSOnlyRedirectHandler(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        newurl = urllib.parse.urljoin(req.full_url, newurl)
        if urllib.parse.urlparse(newurl).scheme != "https":
            raise urllib.error.URLError(f"refusing non-https redirect to {newurl}")
        return super().redirect_request(req, fp, code, msg, headers, newurl)

repo = sys.argv[1]
url = f"https://api.github.com/repos/{repo}/releases/latest"
opener = urllib.request.build_opener(HTTPSOnlyRedirectHandler)
try:
    with opener.open(url, timeout=20) as response:
        if urllib.parse.urlparse(response.geturl()).scheme != "https":
            raise SystemExit("refusing non-https final API URL")
        data = json.load(response)
    tag = str(data.get("tag_name", ""))
    print(tag[1:] if tag.startswith("v") else tag)
except Exception as exc:
    print(exc, file=sys.stderr)
    sys.exit(1)
PY
}

# 判断 $2(latest) 是否严格高于 $1(current)。用 python3 做语义化版本比较：数字段逐段比较
# （缺省段补 0，故 1.7.0.1 > 1.7.0），并按 semver 规则处理预发布后缀（1.0.0 > 1.0.0-rc1）。
# 注意 sort -V 会把 1.0.0-rc1 排在 1.0.0 之上，从而把 rc→正式版误判为降级——故不再使用。
# 解析失败一律按“非更新”返回（fail-closed），避免误触发 root 权限下的自升级。
# Whether $2 (latest) is strictly newer than $1 (current). Uses python3 for semantic version
# comparison: numeric segments compared pairwise (missing segments = 0, so 1.7.0.1 > 1.7.0) and
# pre-release suffixes ranked per semver (1.0.0 > 1.0.0-rc1). sort -V ranks 1.0.0-rc1 ABOVE 1.0.0
# and so mis-gates an rc->final upgrade as a downgrade, which is why it is no longer used here.
# Any parse failure returns "not newer" (fail-closed) so a malformed version can never trigger
# the root-run self-upgrade.
is_newer_version() {
  local current="$1" latest="$2"
  [[ -n "$current" && -n "$latest" ]] || return 1
  [[ "$current" != "$latest" ]] || return 1
  python3 - "$current" "$latest" <<'PY'
import sys

def parse(v):
    v = v.strip()
    if v[:1] == 'v':
        v = v[1:]
    v = v.split('+', 1)[0]                     # semver 构建元数据不参与优先级 / build metadata ignored
    rel, _, pre = v.partition('-')
    parts = rel.split('.') if rel else ['0']
    # 仅接受纯 ASCII 数字段；下划线（int('1_0')==10）、Unicode 数字等一律拒绝 -> 上层 fail-closed。
    # Accept only pure ASCII-digit segments; underscores (int('1_0')==10) and Unicode digits are
    # rejected so a mis-formatted tag can't parse to a bogus number -> fail-closed upstream.
    if not all(p.isascii() and p.isdigit() for p in parts):
        raise ValueError('non-numeric release segment')
    nums = [int(p) for p in parts]
    return nums, pre

def cmp_list(a, b):
    n = max(len(a), len(b))
    a = a + [0] * (n - len(a))
    b = b + [0] * (n - len(b))
    return (a > b) - (a < b)

def cmp_pre(a, b):
    if a == b:
        return 0
    if a == '':                               # 无预发布后缀 > 有预发布后缀 / release outranks pre-release
        return 1
    if b == '':
        return -1
    ai, bi = a.split('.'), b.split('.')
    for x, y in zip(ai, bi):
        if x == y:
            continue
        xn, yn = x.isdigit(), y.isdigit()
        if xn and yn:
            return (int(x) > int(y)) - (int(x) < int(y))
        if xn != yn:                          # 数字标识符优先级低于字母标识符 / numeric < alphanumeric
            return -1 if xn else 1
        return (x > y) - (x < y)
    return (len(ai) > len(bi)) - (len(ai) < len(bi))

def compare(v1, v2):
    r1, p1 = parse(v1)
    r2, p2 = parse(v2)
    c = cmp_list(r1, r2)
    return c if c else cmp_pre(p1, p2)

try:
    sys.exit(0 if compare(sys.argv[2], sys.argv[1]) > 0 else 1)
except Exception:
    sys.exit(1)
PY
}

run_check_upgrade() {
  local latest
  say "当前版本: $VERSION" "Current version: $VERSION"
  say "仓库: $REPO" "Repository: $REPO"
  if ! latest="$(latest_release_version)"; then
    say "无法检查最新版本" "Failed to check latest version" >&2
    return 1
  fi
  say "最新版本: $latest" "Latest version: $latest"
  if [[ "$latest" == "$VERSION" ]]; then
    say "已经是最新版本" "Already up to date"
    return 0
  fi
  if is_newer_version "$VERSION" "$latest"; then
    say "可升级: $VERSION -> $latest" "Upgrade available: $VERSION -> $latest"
    return 0
  fi
  say "本地版本高于 latest release" "Local version is newer than latest release"
  return 0
}

# --check-upgrade / --upgrade 在加载完整配置前就退出；若未显式 --lang，则从 env 文件预读
# NOTIFY_LANG，让这些子命令的显示语言也跟随已安装配置。
# --check-upgrade / --upgrade exit before the full config load; if no explicit --lang, pre-read
# NOTIFY_LANG from the env file so these subcommands' display language follows the installed config.
if [[ -z "${UI_LANG:-}" && -z "${NOTIFY_LANG:-}" && -r "$ENV_FILE" ]]; then
  NOTIFY_LANG="$(sed -n "s/^[[:space:]]*NOTIFY_LANG[[:space:]]*=[[:space:]]*[\"']\{0,1\}\(zh\|en\)[\"']\{0,1\}.*/\1/p" "$ENV_FILE" 2>/dev/null | head -1 || true)"
fi

if [[ "$CHECK_UPGRADE" -eq 1 ]]; then
  run_check_upgrade
  exit $?
fi

download_release_file() {
  # 下载发布文件；优先用 curl，缺失时回退到 python3（运行时已硬依赖 python3）。
  # Download a release file; prefer curl, fall back to python3 (already a hard runtime dependency).
  local url="$1" dest="$2"
  if command -v curl >/dev/null 2>&1; then
    curl --proto '=https' --proto-redir '=https' -fL --retry 3 -o "$dest" "$url"
  else
    python3 - "$url" "$dest" <<'PY'
import shutil
import sys
import urllib.error
import urllib.parse
import urllib.request

class HTTPSOnlyRedirectHandler(urllib.request.HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):
        newurl = urllib.parse.urljoin(req.full_url, newurl)
        if urllib.parse.urlparse(newurl).scheme != "https":
            raise urllib.error.URLError(f"refusing non-https redirect to {newurl}")
        return super().redirect_request(req, fp, code, msg, headers, newurl)

url, dest = sys.argv[1], sys.argv[2]
if urllib.parse.urlparse(url).scheme != "https":
    raise SystemExit("refusing non-https release URL")
opener = urllib.request.build_opener(HTTPSOnlyRedirectHandler)
with opener.open(url, timeout=60) as response, open(dest, "wb") as fh:
    if urllib.parse.urlparse(response.geturl()).scheme != "https":
        raise SystemExit("refusing non-https final release URL")
    shutil.copyfileobj(response, fh)
PY
  fi
}

