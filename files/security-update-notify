#!/usr/bin/env bash
set -uo pipefail

ENV_FILE="${SECURITY_UPDATE_NOTIFY_ENV:-/etc/security-update-notify/telegram.env}"
STATE_DIR="/var/lib/security-update-notify"
STATE_FILE="$STATE_DIR/last-alert.sha256"
STATE_TIME_FILE="$STATE_DIR/last-alert.sent_at"
LOCK_FILE="/run/security-update-notify.lock"
VERSION="1.2.2"
LOG_FILE="/var/log/security-update-notify.log"
TEST_REBOOT=0
SEND_OK=0
NO_DEDUPE=0
DOCTOR=0

usage() {
  cat <<'EOF'
用法 / Usage: security-update-notify [--test-ok] [--test-reboot] [--no-dedupe] [--doctor] [--version]

检查系统后端的整机重启/服务重启状态，然后发送 Telegram 提醒。
Checks OS backend reboot/service-restart state, then sends Telegram alerts.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --test-ok) SEND_OK=1; shift ;;
    --test-reboot) TEST_REBOOT=1; shift ;;
    --no-dedupe) NO_DEDUPE=1; shift ;;
    --doctor) DOCTOR=1; shift ;;
    --version) echo "security-update-notify $VERSION"; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "未知参数 / Unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

mkdir -p "$STATE_DIR"
chmod 0750 "$STATE_DIR" 2>/dev/null || true
exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

log_event() {
  local line="$1"
  mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S %z')" "$line" >>"$LOG_FILE" 2>/dev/null || true
}

load_config_file() {
  local file="$1" line key value
  [[ -r "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" == export\ * ]] && line="${line#export }"
    [[ "$line" == *"="* ]] || { echo "配置行无效 / Invalid config line in $file" >&2; return 2; }
    key="${line%%=*}"
    value="${line#*=}"
    key="${key//[[:space:]]/}"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || { echo "配置键无效 / Invalid config key in $file: $key" >&2; return 2; }
    value="${value#${value%%[![:space:]]*}}"
    value="${value%${value##*[![:space:]]}}"
    if [[ "$value" != \"* && "$value" != \'* ]]; then
      value="${value%%[[:space:]]#*}"
      value="${value%${value##*[![:space:]]}}"
    fi
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then value="${value:1:${#value}-2}"; fi
    if [[ "$value" == \'*\' && "$value" == *\' ]]; then value="${value:1:${#value}-2}"; fi
    case "$key" in
      TELEGRAM_BOT_TOKEN|TELEGRAM_CHAT_ID|HOST_LABEL|NOTIFY_OK|DEDUP_MODE|DEDUP_INTERVAL_DAYS|NOTIFY_LANG|BACKEND)
        printf -v "$key" '%s' "$value"
        ;;
      *) echo "配置键不支持 / Unsupported config key in $file: $key" >&2; return 2 ;;
    esac
  done <"$file"
}

telegram_get_me() {
  printf '%s' "${TELEGRAM_BOT_TOKEN:-}" | python3 -c '
import json, sys, urllib.request

token = sys.stdin.read()
if not token:
    print("缺少 TELEGRAM_BOT_TOKEN / missing TELEGRAM_BOT_TOKEN", file=sys.stderr)
    sys.exit(2)

url = f"https://api.telegram.org/bot{token}/getMe"
try:
    with urllib.request.urlopen(url, timeout=20) as response:
        body = response.read().decode("utf-8", "replace")
except Exception as exc:
    print(exc, file=sys.stderr)
    sys.exit(1)

print(body)
try:
    ok = bool(json.loads(body).get("ok"))
except Exception:
    ok = False
sys.exit(0 if ok else 1)
'
}

telegram_send_message() {
  local text="$1"
  printf '%s\0%s\0%s' "${TELEGRAM_BOT_TOKEN:-}" "${TELEGRAM_CHAT_ID:-}" "$text" | python3 -c '
import json, sys, time, urllib.parse, urllib.request

payload = sys.stdin.buffer.read().split(b"\0", 2)
token = payload[0].decode("utf-8", "replace") if len(payload) > 0 else ""
chat_id = payload[1].decode("utf-8", "replace") if len(payload) > 1 else ""
text = payload[2].decode("utf-8", "replace") if len(payload) > 2 else ""
if not token or not chat_id:
    print("缺少 Telegram token 或 chat id / missing Telegram token or chat id", file=sys.stderr)
    sys.exit(2)

url = f"https://api.telegram.org/bot{token}/sendMessage"
data = urllib.parse.urlencode({
    "chat_id": chat_id,
    "text": text,
    "disable_web_page_preview": "true",
}).encode()

last_error = ""
for attempt in range(3):
    try:
        with urllib.request.urlopen(url, data=data, timeout=30) as response:
            body = response.read().decode("utf-8", "replace")
        try:
            ok = bool(json.loads(body).get("ok"))
        except Exception:
            ok = False
        if ok:
            sys.exit(0)
        last_error = body
    except Exception as exc:
        last_error = str(exc)
    if attempt < 2:
        time.sleep(1)

print(last_error or "Telegram 通知发送失败 / Telegram notification failed", file=sys.stderr)
sys.exit(1)
'
}

load_config_file "$ENV_FILE" || exit $?

HOST="${HOST_LABEL:-$(hostname -f 2>/dev/null || hostname 2>/dev/null || echo unknown)}"
OS_RELEASE_ID=""
OS_RELEASE_PRETTY_NAME="unknown"
if [[ -r /etc/os-release ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    case "$line" in
      ID=*|PRETTY_NAME=*)
        key="${line%%=*}"
        value="${line#*=}"
        if [[ "$value" == \"*\" && "$value" == *\" ]]; then value="${value:1:${#value}-2}"; fi
        if [[ "$value" == \'*\' && "$value" == *\' ]]; then value="${value:1:${#value}-2}"; fi
        case "$key" in
          ID) OS_RELEASE_ID="$value" ;;
          PRETTY_NAME) OS_RELEASE_PRETTY_NAME="$value" ;;
        esac
        ;;
    esac
  done </etc/os-release
fi
OS="$OS_RELEASE_PRETTY_NAME"
KERNEL="$(uname -r 2>/dev/null || echo unknown)"
NOW="$(date '+%Y-%m-%d %H:%M:%S %Z')"
BACKEND="${BACKEND:-auto}"
NOTIFY_LANG="${NOTIFY_LANG:-zh}"
case "$NOTIFY_LANG" in zh|en) ;; *) NOTIFY_LANG="zh" ;; esac

if [[ "$BACKEND" == "auto" ]]; then
  if [[ -n "$OS_RELEASE_ID" ]]; then
    case "$OS_RELEASE_ID" in
      debian|ubuntu) BACKEND="apt" ;;
      rhel|rocky|almalinux|fedora|centos) BACKEND="dnf" ;;
      amzn) BACKEND="dnf" ;;
      *) BACKEND="unknown" ;;
    esac
  else
    BACKEND="unknown"
  fi
fi

run_doctor() {
  local ok=1
  echo "security-update-notify $VERSION"
  echo "配置文件 / Config: $ENV_FILE"
  [[ -r "$ENV_FILE" ]] && echo "正常：配置可读 / OK config readable" || { echo "失败：配置不可读 / FAIL config not readable"; ok=0; }
  echo "后端 / Backend: $BACKEND"
  echo "主机 / Host: $HOST"
  echo "系统 / OS: $OS"
  echo "内核 / Kernel: $KERNEL"
  if [[ -d /run/systemd/system ]] && command -v systemctl >/dev/null 2>&1; then
    echo "正常：systemd 存在 / OK systemd present"
    systemctl is-enabled security-update-notify.timer >/dev/null 2>&1 && echo "正常：timer 已启用 / OK timer enabled" || { echo "警告：timer 未启用 / WARN timer not enabled"; ok=0; }
    systemctl list-timers security-update-notify.timer --no-pager 2>/dev/null || true
  else
    echo "失败：systemd 不可用 / FAIL systemd unavailable"; ok=0
  fi
  case "$BACKEND" in
    apt)
      for c in apt-get dpkg needrestart; do command -v "$c" >/dev/null 2>&1 && echo "正常：命令存在 / OK command $c" || { echo "失败：缺少命令 / FAIL missing command $c"; ok=0; }; done
      dpkg -s unattended-upgrades >/dev/null 2>&1 && echo "正常：unattended-upgrades 已安装 / OK unattended-upgrades installed" || { echo "失败：缺少 unattended-upgrades / FAIL unattended-upgrades missing"; ok=0; }
      ;;
    dnf)
      command -v dnf >/dev/null 2>&1 && echo "正常：命令存在 / OK command dnf" || command -v yum >/dev/null 2>&1 && echo "正常：命令存在 / OK command yum" || { echo "失败：缺少 dnf/yum / FAIL missing dnf/yum"; ok=0; }
      command -v needs-restarting >/dev/null 2>&1 && echo "正常：命令存在 / OK command needs-restarting" || { echo "失败：缺少 needs-restarting / FAIL missing needs-restarting"; ok=0; }
      systemctl is-enabled dnf-automatic.timer >/dev/null 2>&1 && echo "正常：dnf-automatic.timer 已启用 / OK dnf-automatic.timer enabled" || echo "警告：dnf-automatic.timer 未启用 / WARN dnf-automatic.timer not enabled"
      ;;
    *) echo "失败：不支持的后端 / FAIL unsupported backend $BACKEND"; ok=0 ;;
  esac
  if [[ -n "${TELEGRAM_BOT_TOKEN:-}" && -n "${TELEGRAM_CHAT_ID:-}" ]]; then
    echo "正常：Telegram 配置存在 / OK Telegram config present"
    if telegram_get_me >/dev/null; then
      echo "正常：Telegram Bot Token 可用 / OK Telegram bot token works"
    else
      echo "失败：Telegram getMe 失败 / FAIL Telegram getMe failed"; ok=0
    fi
  else
    echo "失败：Telegram 配置缺失 / FAIL Telegram config missing"; ok=0
  fi
  [[ "$ok" -eq 1 ]] || return 1
}

if [[ "$DOCTOR" -eq 1 ]]; then
  run_doctor
  exit $?
fi

reboot_required=0
reboot_pkgs=""
restart_attention=0
restart_summary=""
update_summary=""

check_apt() {
  if [[ "$TEST_REBOOT" -eq 1 ]]; then
    reboot_required=1
    reboot_pkgs=$'linux-image-amd64\nTEST-MODE-no-real-reboot'
    restart_summary=$'NEEDRESTART-VER: test\nNEEDRESTART-KCUR: test-current\nNEEDRESTART-KEXP: test-expected\nNEEDRESTART-KSTA: 3\nNEEDRESTART-SVC: ssh.service'
    restart_attention=1
    return
  fi
  if [[ -f /var/run/reboot-required ]]; then
    reboot_required=1
    reboot_pkgs="$(cat /var/run/reboot-required.pkgs 2>/dev/null | sed '/^$/d' | sort -u)"
  fi
  if command -v needrestart >/dev/null 2>&1; then
    restart_summary="$(needrestart -b 2>&1 || true)"
    local kcur kexp ksta
    kcur="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KCUR:/{print $2; exit}')"
    kexp="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KEXP:/{print $2; exit}')"
    ksta="$(printf '%s\n' "$restart_summary" | awk -F': ' '/^NEEDRESTART-KSTA:/{print $2; exit}')"
    [[ -n "$kcur" && -n "$kexp" && "$kcur" != "$kexp" ]] && restart_attention=1
    [[ -n "$ksta" && "$ksta" != "1" ]] && restart_attention=1
    printf '%s\n' "$restart_summary" | grep -Eq '^NEEDRESTART-(SVC|AUX|SESS|UCSTA|UCCUR|UCEXP):' && restart_attention=1
  else
    restart_summary="needrestart 命令不存在 / needrestart command not found"
  fi
}

check_dnf() {
  if [[ "$TEST_REBOOT" -eq 1 ]]; then
    reboot_required=1
    reboot_pkgs=$'kernel\nTEST-MODE-no-real-reboot'
    restart_summary=$'needs-restarting -r: Reboot is required to ensure that your system benefits from these updates.\nneeds-restarting:\ntest-service (pid 123)'
    restart_attention=1
    return
  fi
  if command -v needs-restarting >/dev/null 2>&1; then
    local nr_r rc nr_all
    rc=0
    nr_r="$(needs-restarting -r 2>&1)" || rc=$?
    if [[ "$rc" -ne 0 ]]; then
      reboot_required=1
    fi
    nr_all="$(needs-restarting 2>&1 || true)"
    restart_summary="needs-restarting -r:\n${nr_r}\n\nneeds-restarting:\n${nr_all}"
    if printf '%s\n' "$nr_all" | sed '/^$/d' | grep -q .; then
      restart_attention=1
    fi
  else
    restart_summary="needs-restarting 命令不存在；请安装 dnf-utils/yum-utils / needs-restarting command not found; install dnf-utils/yum-utils"
  fi
  if command -v dnf >/dev/null 2>&1; then
    update_summary="$(dnf -q updateinfo list security updates 2>/dev/null | sed -n '1,40p' || true)"
  fi
  reboot_pkgs="$(printf '%s\n' "$update_summary" | awk '{print $NF}' | sed '/^$/d' | sort -u | sed -n '1,40p')"
}

format_restart_summary() {
  local lang="$1" summary kcur kexp ksta services service_count other_count processes process_count
  summary="${restart_summary//\\n/$'\n'}"
  case "$BACKEND" in
    apt)
      kcur="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KCUR:/{print $2; exit}')"
      kexp="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KEXP:/{print $2; exit}')"
      ksta="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-KSTA:/{print $2; exit}')"
      services="$(printf '%s\n' "$summary" | awk -F': ' '/^NEEDRESTART-SVC:/{print $2}' | sed '/^$/d' | sort -u)"
      service_count="$(printf '%s\n' "$services" | sed '/^$/d' | wc -l | tr -d ' ')"
      other_count="$(printf '%s\n' "$summary" | grep -Ec '^NEEDRESTART-(AUX|SESS|UCSTA|UCCUR|UCEXP):' || true)"

      if [[ "$lang" == "en" ]]; then
        [[ -n "$kcur" || -n "$kexp" ]] && printf 'Kernel: current %s, expected %s\n' "${kcur:-unknown}" "${kexp:-unknown}"
        [[ -n "$ksta" ]] && printf 'Kernel status code: %s\n' "$ksta"
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf 'Services to review/restart (%s):\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ... and %s more\n' "$((service_count - 12))"
        fi
        [[ "${other_count:-0}" -gt 0 ]] && printf 'Additional sessions/containers/processes need review. Run needrestart on the server for details.\n'
        [[ -z "$kcur$kexp$services" && "${other_count:-0}" -eq 0 ]] && printf 'No detailed restart list was available. Run needrestart -b on the server for details.\n'
      else
        [[ -n "$kcur" || -n "$kexp" ]] && printf '内核：当前 %s，建议 %s\n' "${kcur:-未知}" "${kexp:-未知}"
        [[ -n "$ksta" ]] && printf '内核状态码：%s\n' "$ksta"
        if [[ "${service_count:-0}" -gt 0 ]]; then
          printf '建议评估/重启的服务（%s 个）：\n' "$service_count"
          printf '%s\n' "$services" | sed -n '1,12p' | sed 's/^/• /'
          [[ "$service_count" -gt 12 ]] && printf '• ……另有 %s 个\n' "$((service_count - 12))"
        fi
        [[ "${other_count:-0}" -gt 0 ]] && printf '另有用户会话、容器或进程需要关注；可在服务器上运行 needrestart 查看详情。\n'
        [[ -z "$kcur$kexp$services" && "${other_count:-0}" -eq 0 ]] && printf '没有拿到详细重启列表；可在服务器上运行 needrestart -b 查看详情。\n'
      fi
      ;;
    dnf)
      processes="$(printf '%s\n' "$summary" | awk 'found && NF {print} /^needs-restarting:/{found=1}' | sed -n '1,12p')"
      process_count="$(printf '%s\n' "$summary" | awk 'found && NF {print} /^needs-restarting:/{found=1}' | wc -l | tr -d ' ')"
      if [[ "$lang" == "en" ]]; then
        [[ "$reboot_required" -eq 1 ]] && printf 'Full reboot: required by needs-restarting -r\n'
        if [[ -n "$processes" ]]; then
          printf 'Processes/services to review (%s shown):\n' "$(printf '%s\n' "$processes" | wc -l | tr -d ' ')"
          printf '%s\n' "$processes" | sed 's/^/• /'
          [[ "${process_count:-0}" -gt 12 ]] && printf '• ... and %s more\n' "$((process_count - 12))"
        else
          printf 'No detailed process list was available. Run needs-restarting on the server for details.\n'
        fi
      else
        [[ "$reboot_required" -eq 1 ]] && printf '整机重启：needs-restarting -r 判断为需要\n'
        if [[ -n "$processes" ]]; then
          printf '建议评估的进程/服务（显示 %s 条）：\n' "$(printf '%s\n' "$processes" | wc -l | tr -d ' ')"
          printf '%s\n' "$processes" | sed 's/^/• /'
          [[ "${process_count:-0}" -gt 12 ]] && printf '• ……另有 %s 条\n' "$((process_count - 12))"
        else
          printf '没有拿到详细进程列表；可在服务器上运行 needs-restarting 查看详情。\n'
        fi
      fi
      ;;
  esac
}

case "$BACKEND" in
  apt) check_apt ;;
  dnf) check_dnf ;;
  *) echo "不支持的后端 / Unsupported backend: $BACKEND" >&2; exit 2 ;;
esac

if [[ "$reboot_required" -eq 0 && "$restart_attention" -eq 0 ]]; then
  log_event "check ok backend=$BACKEND host=$HOST no_attention=1"
  if [[ "$SEND_OK" -eq 1 || "${NOTIFY_OK:-0}" == "1" ]]; then
    zh_msg="✅ 安全更新检查正常\n\n主机：$HOST\n系统：$OS\n后端：$BACKEND\n当前内核：$KERNEL\n时间：$NOW\n\n没有发现整机重启或服务/进程重启需要关注的问题。"
    en_msg="✅ Security update check OK\n\nHost: $HOST\nOS: $OS\nBackend: $BACKEND\nCurrent kernel: $KERNEL\nTime: $NOW\n\nNo reboot or service/process restart requiring attention was detected."
    if [[ "$NOTIFY_LANG" == "en" ]]; then
      msg="$en_msg\n\n---\n\n$zh_msg"
    else
      msg="$zh_msg\n\n---\n\n$en_msg"
    fi
  else
    log_event "silent ok backend=$BACKEND host=$HOST"
    exit 0
  fi
else
  pkgs_zh="无"
  pkgs_en="None"
  if [[ -n "$reboot_pkgs" ]]; then
    pkgs_zh="$reboot_pkgs"
    pkgs_en="$reboot_pkgs"
  fi
  rs_zh="$(format_restart_summary zh | sed -n '1,80p')"
  rs_en="$(format_restart_summary en | sed -n '1,80p')"
  reboot_text_zh="$([[ "$reboot_required" -eq 1 ]] && echo '需要' || echo '暂不需要')"
  reboot_text_en="$([[ "$reboot_required" -eq 1 ]] && echo 'Required' || echo 'Not required for now')"
  zh_msg="⚠️ 安全更新后需要处理\n\n主机：$HOST\n系统：$OS\n后端：$BACKEND\n当前内核：$KERNEL\n时间：$NOW\n\n整机重启：$reboot_text_zh\n相关包/安全更新：\n$pkgs_zh\n\n重启检测摘要：\n$rs_zh\n\n建议：请在方便的维护窗口 SSH 登录该服务器后手动执行 reboot；如只是服务需要重启，可先评估并重启对应服务。"
  en_msg="⚠️ Security update action required\n\nHost: $HOST\nOS: $OS\nBackend: $BACKEND\nCurrent kernel: $KERNEL\nTime: $NOW\n\nFull reboot: $reboot_text_en\nRelated packages/security updates:\n$pkgs_en\n\nRestart detection summary:\n$rs_en\n\nRecommendation: SSH into this server during a suitable maintenance window and run reboot if a full reboot is required. If only services need restarting, review them first and restart the affected services manually."
  if [[ "$NOTIFY_LANG" == "en" ]]; then
    msg="$en_msg\n\n---\n\n$zh_msg"
  else
    msg="$zh_msg\n\n---\n\n$en_msg"
  fi
fi
msg="${msg//\\n/$'\n'}"


alert_hash="$(printf '%s\n%s\n%s\n%s\n%s\n%s\n' "$HOST" "$BACKEND" "$reboot_required" "$reboot_pkgs" "$restart_attention" "$restart_summary" | sha256sum | awk '{print $1}')"
last_hash="$(cat "$STATE_FILE" 2>/dev/null || true)"
last_sent="$(cat "$STATE_TIME_FILE" 2>/dev/null || echo 0)"
now_epoch="$(date +%s)"
dedup_mode="${DEDUP_MODE:-interval}"
dedup_days="${DEDUP_INTERVAL_DAYS:-3}"
[[ "$dedup_days" =~ ^[0-9]+$ && "$dedup_days" -ge 1 ]] || dedup_days=3
should_send=1
if [[ "$NO_DEDUPE" -ne 1 && "$alert_hash" == "$last_hash" ]]; then
  case "$dedup_mode" in
    always) should_send=0 ;;
    daily)
      last_day="$(date -d "@$last_sent" +%F 2>/dev/null || echo '')"
      today="$(date +%F)"
      [[ "$last_day" == "$today" ]] && should_send=0
      ;;
    interval|*)
      interval_seconds=$(( dedup_days * 86400 ))
      if [[ "$last_sent" =~ ^[0-9]+$ ]] && (( now_epoch - last_sent < interval_seconds )); then should_send=0; fi
      ;;
  esac
fi
if [[ "$should_send" -eq 0 ]]; then
  log_event "dedup suppressed backend=$BACKEND host=$HOST mode=$dedup_mode hash=$alert_hash"
  exit 0
fi

if [[ -z "${TELEGRAM_BOT_TOKEN:-}" || -z "${TELEGRAM_CHAT_ID:-}" ]]; then
  echo "在 $ENV_FILE 中缺少 TELEGRAM_BOT_TOKEN 或 TELEGRAM_CHAT_ID / Missing TELEGRAM_BOT_TOKEN or TELEGRAM_CHAT_ID in $ENV_FILE" >&2
  exit 2
fi

if telegram_send_message "$msg"; then
  printf '%s\n' "$alert_hash" >"$STATE_FILE"
  printf '%s\n' "$now_epoch" >"$STATE_TIME_FILE"
  log_event "telegram sent backend=$BACKEND host=$HOST reboot_required=$reboot_required restart_attention=$restart_attention hash=$alert_hash"
else
  log_event "telegram failed backend=$BACKEND host=$HOST"
  echo "Telegram 通知发送失败 / Telegram notification failed" >&2
  exit 1
fi
