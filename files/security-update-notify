# ====== 安全更新看门狗：自动更新健康 / 待安装安全更新 / 发行版 EOL ======
# ====== Security-update watchdog: auto-update health / pending security updates / distro EOL ======
HEALTH_ATTENTION=0; HEALTH_SIG=""; HEALTH_TXT_ZH=""; HEALTH_TXT_EN=""
PENDING_SEC_COUNT=0; PENDING_SEC_CRIT=0; PENDING_TXT_ZH=""; PENDING_TXT_EN=""
EOL_ATTENTION=0; EOL_SIG=""; EOL_TXT_ZH=""; EOL_TXT_EN=""

# 检测自动安全更新机制是否健康：定时器是否启用、上次是否成功、距上次成功是否过久、磁盘是否将满。
# Detect whether the automatic security-update mechanism is healthy: timer enabled, last run succeeded,
# not stale, and disk not nearly full.
check_update_health() {
  [[ "${CHECK_UPDATE_HEALTH:-1}" == "1" ]] || return 0
  command -v systemctl >/dev/null 2>&1 || return 0
  local timer svc now last_ts last_epoch last_trigger trigger_epoch res stale_days days mp avail
  local reasons=()
  case "$BACKEND" in
    apt) timer="apt-daily-upgrade.timer"; svc="apt-daily-upgrade.service" ;;
    dnf) timer="dnf-automatic.timer"; svc="dnf-automatic.service" ;;
    *) return 0 ;;
  esac
  now="$(date +%s)"
  if ! systemctl is-enabled "$timer" >/dev/null 2>&1; then
    HEALTH_ATTENTION=1; reasons+=("disabled")
    HEALTH_TXT_ZH+="• 自动安全更新定时器未启用（$timer）"$'\n'
    HEALTH_TXT_EN+="• Automatic security-update timer is not enabled ($timer)"$'\n'
  fi
  res="$(systemctl show "$svc" -p Result --value 2>/dev/null || true)"
  if [[ -n "$res" && "$res" != "success" ]]; then
    HEALTH_ATTENTION=1; reasons+=("failed")
    HEALTH_TXT_ZH+="• 上次自动更新运行失败（$svc：$res）"$'\n'
    HEALTH_TXT_EN+="• The last automatic-update run failed ($svc: $res)"$'\n'
  fi
  stale_days="${STALE_UPDATE_DAYS:-7}"; [[ "$stale_days" =~ ^[0-9]+$ ]] || stale_days=7
  if [[ "$stale_days" -gt 0 ]]; then
    last_ts="$(systemctl show "$svc" -p ExecMainExitTimestamp --value 2>/dev/null || true)"
    if [[ -n "$last_ts" ]]; then
      last_epoch="$(date -d "$last_ts" +%s 2>/dev/null || echo 0)"
      if [[ "$last_epoch" =~ ^[0-9]+$ && "$last_epoch" -gt 0 ]] && (( now - last_epoch > stale_days * 86400 )); then
        days=$(( (now - last_epoch) / 86400 ))
        HEALTH_ATTENTION=1; reasons+=("stale")
        HEALTH_TXT_ZH+="• 已 $days 天没有成功的自动安全更新（阈值 $stale_days 天）"$'\n'
        HEALTH_TXT_EN+="• No successful automatic security update for $days days (threshold $stale_days)"$'\n'
      fi
    else
      last_trigger="$(systemctl show "$timer" -p LastTriggerUSec --value 2>/dev/null || true)"
      if [[ -n "$last_trigger" && "$last_trigger" != "n/a" ]]; then
        trigger_epoch="$(date -d "$last_trigger" +%s 2>/dev/null || echo 0)"
        if [[ "$trigger_epoch" =~ ^[0-9]+$ && "$trigger_epoch" -gt 0 ]] && (( now - trigger_epoch > stale_days * 86400 )); then
          days=$(( (now - trigger_epoch) / 86400 ))
          HEALTH_ATTENTION=1; reasons+=("never-success")
          HEALTH_TXT_ZH+="• 自动安全更新定时器已触发过，但没有成功运行记录（最近触发约 $days 天前）"$'\n'
          HEALTH_TXT_EN+="• The automatic-update timer has triggered, but no successful run was recorded (last trigger ~${days} days ago)"$'\n'
        fi
      fi
    fi
  fi
  for mp in / /boot; do
    [[ -d "$mp" ]] || continue
    avail="$(df -P -k "$mp" 2>/dev/null | awk 'NR==2{print $4}')"
    [[ "$avail" =~ ^[0-9]+$ ]] || continue
    if (( avail < 204800 )); then
      HEALTH_ATTENTION=1; reasons+=("disk")
      HEALTH_TXT_ZH+="• $mp 剩余空间不足（$(( avail/1024 )) MB），可能导致更新失败"$'\n'
      HEALTH_TXT_EN+="• Low free space on $mp ($(( avail/1024 )) MB); updates may fail"$'\n'
    fi
  done
  HEALTH_TXT_ZH="${HEALTH_TXT_ZH%$'\n'}"; HEALTH_TXT_EN="${HEALTH_TXT_EN%$'\n'}"
  [[ ${#reasons[@]} -gt 0 ]] && HEALTH_SIG="$(printf '%s\n' "${reasons[@]}" | sort -u | tr '\n' ',')"
}

# 统计仍待安装的安全更新数量（dnf 还区分高危/重要）。仅作信息展示，不单独触发告警。
# Count pending (not-yet-installed) security updates (dnf also counts critical/important). Informational only.
collect_security_updates() {
  local out
  case "$BACKEND" in
    dnf)
      command -v dnf >/dev/null 2>&1 || return 0
      out="$(dnf -q updateinfo list security 2>/dev/null || true)"
      PENDING_SEC_COUNT="$(printf '%s\n' "$out" | awk '$NF ~ /\.(x86_64|noarch|aarch64|i686|ppc64le|s390x)$/' | wc -l | tr -d ' ')"
      PENDING_SEC_CRIT="$(printf '%s\n' "$out" | awk 'tolower($0) ~ /critical/ && $NF ~ /\.(x86_64|noarch|aarch64|i686|ppc64le|s390x)$/' | wc -l | tr -d ' ')"
      ;;
    apt)
      command -v apt-get >/dev/null 2>&1 || return 0
      out="$(apt-get -s upgrade 2>/dev/null || true)"
      PENDING_SEC_COUNT="$(printf '%s\n' "$out" | awk '/^Inst / && tolower($0) ~ /security/' | wc -l | tr -d ' ')"
      ;;
    *) return 0 ;;
  esac
  [[ "$PENDING_SEC_COUNT" =~ ^[0-9]+$ ]] || PENDING_SEC_COUNT=0
  [[ "$PENDING_SEC_CRIT" =~ ^[0-9]+$ ]] || PENDING_SEC_CRIT=0
  if [[ "$PENDING_SEC_COUNT" -gt 0 ]]; then
    if [[ "$PENDING_SEC_CRIT" -gt 0 ]]; then
      PENDING_TXT_ZH="待安装安全更新：$PENDING_SEC_COUNT 个（其中高危/重要 $PENDING_SEC_CRIT 个）"
      PENDING_TXT_EN="Pending security updates: $PENDING_SEC_COUNT ($PENDING_SEC_CRIT critical/important)"
    else
      PENDING_TXT_ZH="待安装安全更新：$PENDING_SEC_COUNT 个"
      PENDING_TXT_EN="Pending security updates: $PENDING_SEC_COUNT"
    fi
  fi
}

# 各发行版“安全支持终止”近似日期（best-effort，需随时间维护；Fedora 生命周期短，故意不列）。
# Approximate security end-of-life per release (best-effort; maintain over time; Fedora intentionally omitted).
eol_date_for() {
  local id="$1" ver="$2" pretty="${3:-}" major="${2%%.*}"
  case "$id" in
    debian) case "$ver" in 11) echo 2026-08-31 ;; 12) echo 2028-06-30 ;; 13) echo 2030-06-30 ;; esac ;;
    ubuntu) case "$ver" in 20.04) echo 2025-05-31 ;; 22.04) echo 2027-06-01 ;; 24.04) echo 2029-05-31 ;; esac ;;
    rhel|rocky|ol|cloudlinux) case "$major" in 8) echo 2029-05-31 ;; 9) echo 2032-05-31 ;; 10) echo 2035-05-31 ;; esac ;;
    almalinux) case "$major" in 8) echo 2029-03-01 ;; 9) echo 2032-05-31 ;; 10) echo 2035-05-31 ;; esac ;;
    centos)
      if [[ "$pretty" == *"Stream"* ]]; then
        case "$major" in 8) echo 2024-05-31 ;; 9) echo 2027-05-31 ;; esac
      else
        case "$major" in 7) echo 2024-06-30 ;; 8) echo 2021-12-31 ;; esac
      fi
      ;;
    amzn) case "$ver" in 2023) echo 2029-06-30 ;; esac ;;
  esac
}

# 发行版安全支持即将/已经终止时告警（已过 EOL=触发告警；临近=仅信息，避免提前数月反复打扰）。
# Warn when distro security support is ending/ended (past EOL triggers an alert; approaching is informational).
check_eol() {
  [[ "${CHECK_EOL:-1}" == "1" ]] || return 0
  local eol now eol_epoch days warn_days=90
  eol="$(eol_date_for "${OS_RELEASE_ID:-}" "${OS_RELEASE_VERSION_ID:-}" "${OS_RELEASE_PRETTY_NAME:-}")"
  [[ -n "$eol" ]] || return 0
  now="$(date +%s)"
  eol_epoch="$(date -d "$eol" +%s 2>/dev/null || echo 0)"
  [[ "$eol_epoch" =~ ^[0-9]+$ && "$eol_epoch" -gt 0 ]] || return 0
  if (( now > eol_epoch )); then
    EOL_ATTENTION=1; EOL_SIG="past"
    EOL_TXT_ZH="⛔ 本系统的安全支持已于 $eol 终止，将不再收到安全更新，请尽快规划升级发行版。"
    EOL_TXT_EN="⛔ Security support for this release ended on $eol; it no longer receives security updates. Plan a distro upgrade."
  elif (( eol_epoch - now < warn_days * 86400 )); then
    days=$(( (eol_epoch - now) / 86400 ))
    EOL_SIG="soon"
    EOL_TXT_ZH="⚠️ 本系统的安全支持将于 $eol 终止（约剩 $days 天），请规划升级。"
    EOL_TXT_EN="⚠️ Security support for this release ends on $eol (~$days days left). Plan an upgrade."
  fi
}

