  check_eol
  if [[ "$HEALTH_ATTENTION" -eq 1 ]]; then
    say "失败：自动安全更新机制异常" "FAIL automatic security-update mechanism issue"; ok=0
    say "$HEALTH_TXT_ZH" "$HEALTH_TXT_EN"
  else
    say "正常：自动安全更新机制健康" "OK automatic security-update mechanism healthy"
  fi
  if [[ "$PENDING_SEC_COUNT" -gt 0 ]]; then
    say "$PENDING_TXT_ZH" "$PENDING_TXT_EN"
  else
    say "正常：当前无待安装的安全更新" "OK no pending security updates"
  fi
  if [[ -n "$EOL_TXT_ZH" ]]; then
    [[ "$EOL_ATTENTION" -eq 1 ]] && ok=0
    say "$EOL_TXT_ZH" "$EOL_TXT_EN"
  else
    say "正常：发行版仍在安全支持期内（或不在 EOL 表中）" "OK release within security support (or not in the EOL table)"
  fi
  [[ "$ok" -eq 1 ]] || return 1
}

